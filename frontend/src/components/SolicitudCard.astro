---
interface Props {
	citizenName: string;
	area: string;
	delegation: string;
	token: string;
	folio: string;
	date: string;
	status: 'Aprobado' | 'Declinado' | 'Recibido' | 'En revisión';
}

const { citizenName, area, delegation, token, folio, date, status } = Astro.props;

// Determine mock validation checks based on status
const isApproved = status === 'Aprobado';
const hasValidationRun = true; // Simulated auto validation is always active
---

<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between relative overflow-hidden group">
	<!-- Top indicator border -->
	<div class={`absolute top-0 left-0 w-full h-1.5 ${isApproved ? 'bg-emerald-500' : 'bg-red-500'}`}></div>

	<div class="space-y-4">
		<!-- Header with Folio and Date -->
		<div class="flex justify-between items-center text-[10px] text-slate-400 font-bold tracking-wider">
			<span class="font-mono bg-slate-100 px-2 py-0.5 rounded text-slate-700 border border-slate-200/50">{folio}</span>
			<span>{date}</span>
		</div>

		<!-- Citizen Info -->
		<div class="space-y-1">
			<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest block">Ciudadano</span>
			<h4 class="text-base font-bold text-slate-800 leading-tight font-display">{citizenName}</h4>
		</div>

		<!-- Request Info -->
		<div class="grid grid-cols-2 gap-3 pt-1 text-xs">
			<div>
				<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest block">Área / Trámite</span>
				<span class="font-semibold text-slate-700 block mt-0.5 leading-tight">{area}</span>
			</div>
			<div>
				<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest block">Delegación / Lugar</span>
				<span class="font-semibold text-slate-700 block mt-0.5 leading-tight">{delegation}</span>
			</div>
		</div>

		<!-- Token de Seguimiento -->
		<div class="p-3 bg-slate-50 rounded-xl border border-slate-200/50">
			<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest block mb-1">Token de Seguimiento</span>
			<div class="flex justify-between items-center">
				<code class="font-mono text-xs font-bold text-yuc-green tracking-wider">{token}</code>
				<button 
					type="button" 
					class="p-1 text-slate-400 hover:text-yuc-green rounded hover:bg-slate-100 transition-colors"
					onclick={`navigator.clipboard.writeText('${token}'); window.showToast('Token copiado al portapapeles', 'success');`}
					title="Copiar Token"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m9.75-4.875c.621 0 1.125.504 1.125 1.125V2.25M7.875 6h9.75c.621 0 1.125.504 1.125 1.125V18a1.125 1.125 0 01-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H18" />
					</svg>
				</button>
			</div>
		</div>

		<!-- Automated Validation Section (Simulada) -->
		<div class="pt-4 border-t border-slate-100 space-y-3">
			<div class="flex items-center justify-between">
				<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest flex items-center gap-1">
					<span class="w-1.5 h-1.5 rounded-full bg-yuc-green animate-ping"></span>
					Validación Algorítmica Gubernamental
				</span>
				<span class={`px-2 py-0.5 rounded-full text-[9px] font-extrabold uppercase ${isApproved ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : 'bg-red-500/10 text-red-500 border border-red-500/20'}`}>
					{isApproved ? 'Aprobado' : 'Declinado'}
				</span>
			</div>

			<!-- Checkboxes listing automatic registry verifications -->
			<div class="grid grid-cols-2 gap-2 text-[10px]">
				<div class="flex items-center gap-1.5 text-slate-500">
					<svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
						<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
					</svg>
					<span>Cruce CURP (Renapo)</span>
				</div>
				<div class="flex items-center gap-1.5 text-slate-500">
					<svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
						<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
					</svg>
					<span>INE Cotejado</span>
				</div>
				<div class="flex items-center gap-1.5 text-slate-500">
					<svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
						<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
					</svg>
					<span>Comprobante Yucatán</span>
				</div>
				<div class="flex items-center gap-1.5 text-slate-500">
					{isApproved ? (
						<svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
						</svg>
						<span>Vigencia Fiscal</span>
					) : (
						<svg class="w-3.5 h-3.5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
						</svg>
						<span class="text-red-500 font-semibold">Fallo Cruce SAT</span>
					)}
				</div>
			</div>
		</div>

	</div>

	<!-- Bottom Dictamen Badge Overlay -->
	<div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center text-[10px] text-slate-400 font-medium">
		<span>Dictamen:</span>
		<span class={`font-extrabold ${isApproved ? 'text-emerald-600' : 'text-red-600'}`}>
			{isApproved ? 'SISTEMA VALIDADO' : 'CORRECCIÓN REQUERIDA'}
		</span>
	</div>
</div>
