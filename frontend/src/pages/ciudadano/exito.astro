---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Trámite Enviado Exitosamente - CivicFlow">
	<div class="min-h-[calc(100vh-13rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-bg-dark transition-colors relative overflow-hidden">
		
		<!-- Decorative Background Details -->
		<div class="absolute top-0 right-0 w-96 h-96 bg-yuc-green/5 rounded-full blur-3xl pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 w-96 h-96 bg-yuc-gold/5 rounded-full blur-3xl pointer-events-none"></div>

		<div class="max-w-2xl w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-xl p-8 sm:p-10 relative z-10 text-center space-y-8">
			
			<!-- Success Animation Header -->
			<div class="space-y-3">
				<div class="w-20 h-20 bg-emerald-500/10 text-emerald-500 rounded-full flex items-center justify-center mx-auto shadow-inner relative">
					<span class="absolute inset-0 rounded-full bg-emerald-500/20 animate-ping"></span>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-10 h-10 relative z-10">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0110 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0114 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
					</svg>
				</div>
				<h2 class="text-3xl font-black text-slate-800 dark:text-white font-display">¡Envío Exitoso!</h2>
				<p class="text-xs text-slate-500 dark:text-slate-400 max-w-md mx-auto">
					Su solicitud ha sido recibida y registrada por el sistema de automatización gubernamental CivicFlow del Estado de Yucatán.
				</p>
			</div>

			<!-- Folio & Token Area -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				
				<!-- Folio Card -->
				<div class="bg-slate-50 dark:bg-slate-950 border border-slate-200/60 dark:border-slate-850 p-5 rounded-2xl">
					<span class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest block mb-1">Folio Oficial de Registro</span>
					<span id="lbl-success-folio" class="text-xl font-bold font-mono text-slate-800 dark:text-white">TRM-2026-00000</span>
					<p class="text-[10px] text-slate-400 mt-2">Identificador único del trámite</p>
				</div>

				<!-- Token Card (Pantalla Grande) -->
				<div class="bg-yuc-green/5 border border-yuc-green/20 p-5 rounded-2xl relative group">
					<span class="text-[9px] font-extrabold text-yuc-green dark:text-yuc-green-light uppercase tracking-widest block mb-1">Token de Seguimiento</span>
					<div class="flex justify-center items-center gap-2">
						<span id="lbl-success-token" class="text-2xl font-black font-mono text-yuc-green dark:text-yuc-green-light tracking-wide">TK-000000</span>
						<button 
							type="button" 
							id="btn-copy-token" 
							class="p-1.5 text-slate-400 hover:text-yuc-green dark:hover:text-yuc-green-light rounded hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors"
							title="Copiar Token"
						>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m9.75-4.875c.621 0 1.125.504 1.125 1.125V2.25M7.875 6h9.75c.621 0 1.125.504 1.125 1.125V18a1.125 1.125 0 01-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H18" />
							</svg>
						</button>
					</div>
					<p class="text-[10px] text-slate-400 mt-2">Guarde esta clave para consultas rápidas</p>
				</div>

			</div>

			<!-- PDF Download and QR Preview Container -->
			<div class="border border-slate-200 dark:border-slate-800 rounded-2xl p-6 bg-slate-50/50 dark:bg-slate-950/20 flex flex-col md:flex-row items-center gap-6 text-left">
				
				<!-- QR Mockup -->
				<div class="bg-white p-3 rounded-xl border border-slate-200 shadow-sm shrink-0">
					<!-- Visual SVG QR -->
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-24 h-24 text-slate-900">
						<rect width="100" height="100" fill="white" />
						<!-- Outer corners -->
						<rect x="5" y="5" width="25" height="25" fill="currentColor" />
						<rect x="9" y="9" width="17" height="17" fill="white" />
						<rect x="13" y="13" width="9" height="9" fill="currentColor" />

						<rect x="70" y="5" width="25" height="25" fill="currentColor" />
						<rect x="74" y="9" width="17" height="17" fill="white" />
						<rect x="78" y="13" width="9" height="9" fill="currentColor" />

						<rect x="5" y="70" width="25" height="25" fill="currentColor" />
						<rect x="9" y="74" width="17" height="17" fill="white" />
						<rect x="13" y="78" width="9" height="9" fill="currentColor" />
						
						<!-- Center points / modules -->
						<rect x="40" y="15" width="5" height="10" fill="currentColor" />
						<rect x="50" y="5" width="10" height="5" fill="currentColor" />
						<rect x="45" y="45" width="10" height="10" fill="currentColor" />
						<rect x="15" y="40" width="15" height="5" fill="currentColor" />
						<rect x="40" y="75" width="10" height="15" fill="currentColor" />
						<rect x="75" y="40" width="15" height="10" fill="currentColor" />
						<rect x="80" y="80" width="10" height="10" fill="currentColor" />
					</svg>
				</div>

				<div class="space-y-3 flex-grow">
					<div>
						<h4 class="font-bold text-sm text-slate-800 dark:text-white font-display">Acuse del Expediente Digital Único</h4>
						<p class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5 leading-relaxed">
							Se ha compilado un acuse oficial en formato PDF firmado digitalmente que acredita el cumplimiento de entrega de requisitos estatales.
						</p>
					</div>
					
					<button 
						type="button" 
						id="btn-download-receipt" 
						class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-white text-xs font-bold rounded-lg transition-all shadow-sm flex items-center gap-2 border border-slate-750"
					>
						<svg class="w-4 h-4 text-yuc-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
						<span>Descargar Acuse Recibo (PDF)</span>
					</button>
				</div>

			</div>

			<!-- Redirections -->
			<div class="pt-6 border-t border-slate-150 dark:border-slate-800 flex flex-col sm:flex-row gap-4 sm:justify-end">
				<a 
					href="/ciudadano" 
					class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-350 text-xs font-bold rounded-xl transition-all border border-slate-250/50 dark:border-slate-750/50 text-center"
				>
					Volver a Mi Cuenta
				</a>
				<a 
					id="lnk-go-tracker"
					href="/ciudadano/tracker" 
					class="px-6 py-2.5 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-extrabold rounded-xl shadow-md transition-all text-center"
				>
					Ir al Rastrear Estado
				</a>
			</div>

		</div>
	</div>

	<script is:inline>
		const logged = localStorage.getItem('citizen_logged');
		if (logged !== 'true') {
			window.location.href = '/ciudadano/login';
		} else {
			
			// Read folio and token from params
			const params = new URLSearchParams(window.location.search);
			const token = params.get('token') || 'TK-128492';
			const folio = params.get('folio') || 'TRM-2026-00201';
			const tramiteId = params.get('tramite') || 'ssp';

			document.getElementById('lbl-success-folio').textContent = folio;
			document.getElementById('lbl-success-token').textContent = token;

			// Update tracker redirection link
			document.getElementById('lnk-go-tracker').href = `/ciudadano/tracker?folio=${folio}`;

			// Copy token action
			document.getElementById('btn-copy-token').addEventListener('click', () => {
				navigator.clipboard.writeText(token);
				window.showToast("Token copiado al portapapeles", "success");
			});

			// Download PDF receipt simulation
			document.getElementById('btn-download-receipt').addEventListener('click', () => {
				const curp = localStorage.getItem('citizen_curp');
				const name = localStorage.getItem('citizen_fullname') || 'Ciudadano Demo';
				const email = localStorage.getItem('citizen_email');
				const dateStr = new Date().toLocaleString();

				let pdfText = "data:text/plain;charset=utf-8,";
				pdfText += `=========================================================================\n`;
				pdfText += `       GOBIERNO DEL ESTADO DE YUCATÁN - VENTANILLA ÚNICA DIGITAL\n`;
				pdfText += `              COMPROBANTE OFICIAL DE ENTREGA DE EXPEDIENTE\n`;
				pdfText += `=========================================================================\n\n`;
				pdfText += `DATOS DE LA SOLICITUD:\n`;
				pdfText += `----------------------\n`;
				pdfText += `Folio de Trámite:      ${folio}\n`;
				pdfText += `Token de Seguimiento:  ${token}\n`;
				pdfText += `Fecha de Registro:     ${dateStr}\n`;
				pdfText += `Estatus de Envío:      Recibido (En cola de validación)\n\n`;
				pdfText += `DATOS DEL CIUDADANO:\n`;
				pdfText += `--------------------\n`;
				pdfText += `Nombre del Titular:    ${name}\n`;
				pdfText += `CURP del Solicitante:  ${curp}\n`;
				pdfText += `Correo de Contacto:    ${email}\n\n`;
				pdfText += `SELLO DIGITAL DE SEGURIDAD GUBERNAMENTAL:\n`;
				pdfText += `-----------------------------------------\n`;
				pdfText += `CF-YUC-SECURE-STAMP-HACKATEC2026-${token}-VERIFIED-RENAPO-OK\n\n`;
				pdfText += `=========================================================================\n`;
				pdfText += `Este acuse constituye el comprobante digital visual del trámite.\n`;
				pdfText += `Puede verificar el estado de su trámite ingresando su Token de seguimiento\n`;
				pdfText += `en la dirección: http://localhost:4321/ciudadano/tracker\n`;
				pdfText += `=========================================================================\n`;

				const encodedUri = encodeURI(pdfText);
				const link = document.createElement("a");
				link.setAttribute("href", encodedUri);
				link.setAttribute("download", `acuse_civicflow_${folio}.txt`);
				document.body.appendChild(link);
				link.click();
				document.body.removeChild(link);
				window.showToast("Acuse de Recibo descargado exitosamente", "success");
			});

		}
	</script>
</Layout>
