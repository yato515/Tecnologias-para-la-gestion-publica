---
import Layout from '../../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Mi Portal Ciudadano">
	
	<!-- Top Welcome banner -->
	<section class="bg-yuc-green-dark text-white py-10 border-b border-yuc-gold/30">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
			<div>
				<span class="text-xs font-bold text-yuc-gold uppercase tracking-wider font-display">GOBIERNO DEL ESTADO DE YUCATÁN</span>
				<h1 class="text-3xl font-extrabold font-display mt-1">Mi Portal Ciudadano</h1>
				<p class="text-slate-200 text-sm mt-1">CURP: <span id="lbl-curp" class="font-mono font-bold text-white">Cargando...</span> | Sesión: <span id="lbl-email" class="font-bold text-white">Cargando...</span> | Token de Expediente: <span id="lbl-token" class="font-mono font-bold text-yuc-gold text-base cursor-pointer hover:underline" title="Ver completo">Cargando...</span></p>
			</div>
			<div>
				<button 
					id="btn-logout" 
					class="px-4 py-2 border border-white/20 hover:bg-white/10 text-white rounded-lg text-xs font-bold transition-all"
				>
					Cerrar Sesión
				</button>
			</div>
		</div>
	</section>

	<!-- Main Workspace -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
		
		<!-- Protected Route Alert overlay (hidden by default) -->
		<div id="login-required-overlay" class="hidden bg-yellow-50 border border-yellow-200 rounded-2xl p-8 text-center max-w-lg mx-auto space-y-6 shadow-sm">
			<div class="w-16 h-16 rounded-full bg-yellow-100 text-yellow-600 flex items-center justify-center mx-auto">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
			</div>
			<div class="space-y-2">
				<h3 class="text-xl font-bold text-slate-800">Se requiere Iniciar Sesión</h3>
				<p class="text-sm text-slate-500">Para ingresar a este portal y realizar trámites, primero debe identificarse como ciudadano.</p>
			</div>
			<a href="/ciudadano/login" class="inline-block px-6 py-3 bg-yuc-green text-white hover:bg-yuc-green-light font-bold rounded-xl shadow-sm text-sm">
				Iniciar Sesión Ahora
			</a>
		</div>

		<!-- Main Workspace Content (Visible only when logged in) -->
		<div id="hub-content" class="space-y-8">
			
			<!-- Tabs Selection -->
			<div class="flex border-b border-slate-200 gap-6">
				<button 
					id="tab-btn-catalog" 
					class="pb-4 px-1 text-sm font-extrabold border-b-2 border-yuc-green text-yuc-green focus:outline-none flex items-center gap-2"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
					</svg>
					<span class="font-display">Catálogo de Trámites</span>
				</button>
				<button 
					id="tab-btn-inbox" 
					class="pb-4 px-1 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-850 focus:outline-none flex items-center gap-2 relative"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 9v.906a2.25 2.25 0 01-1.183 1.981l-6.478 3.488M2.25 9v.906a2.25 2.25 0 001.183 1.981l6.478 3.488m8.839 2.51l-4.66-2.51m0 0l-1.023-.55a2.25 2.25 0 00-2.134 0l-1.022.55m0 0l-4.661 2.51m16.5 1.615a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V8.844a2.25 2.25 0 011.183-1.98l7.5-4.04a2.25 2.25 0 012.134 0l7.5 4.04a2.25 2.25 0 011.183 1.98V19.5z" />
					</svg>
					<span class="font-display">Mi Bandeja de Trámites</span>
					<!-- Badge of count -->
					<span id="badge-inbox-count" class="hidden bg-yuc-gold text-white font-extrabold text-[10px] w-5 h-5 rounded-full items-center justify-center">0</span>
				</button>
				<button 
					id="tab-btn-folder" 
					class="pb-4 px-1 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-850 focus:outline-none flex items-center gap-2 relative"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18m-18 0v-4.5m18 4.5v-4.5m-18 0a2.25 2.25 0 014.5-9h15a2.25 2.25 0 0121.75 11.25M3 13.5v5.25c0 .621.504 1.125 1.125 1.125h15.75c.621 0 1.125-.504 1.125-1.125V13.5" />
					</svg>
					<span class="font-display">Mi Expediente Digital</span>
				</button>
			</div>

			<!-- TAB 1: CATALOG OF PROCEDURES -->
			<div id="tab-content-catalog" class="space-y-6">
				<!-- Search bar -->
				<div class="relative max-w-md">
					<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
						</svg>
					</div>
					<input 
						id="txt-search"
						type="text" 
						class="block w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm text-slate-800 placeholder-slate-400 focus:outline-none"
						placeholder="Buscar trámite por palabra clave (ej: residencia, henequén)..."
					/>
				</div>

				<!-- Catalog Cards Grid -->
				<div id="catalog-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
					
					<!-- Card 1: SSP (Licencias y Placas) -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="ssp licencias placas conducir vehiculo seguridad publica yucatan">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">SEGURIDAD PÚBLICA (SSP)</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: 1 día</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Licencia de Conducir y Placas</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Trámite oficial para expedición, renovación y duplicado de licencias para conducir, así como alta, reemplacamiento e inspección de placas vehiculares en el Estado.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• Identificación oficial (INE) • Comprobante de domicilio reciente • Pago de derechos</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Variable</span>
							<a href="/ciudadano/tramite?id=ssp" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 2: SAT (Alta de RFC y Citas) -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="sat rfc fiscal contribuyente hacienda citas alta cedula">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-gold/15 text-yuc-gold-dark font-bold text-[10px] uppercase font-display">HACIENDA / SAT</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: Redirección</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Inscripción en el RFC (SAT)</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Alta y obtención de la Cédula de Identificación Fiscal. Requiere validación de homoclave ante el SAT para la facturación y trámites estatales de fomento.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• CURP oficial • Cuenta de correo • e.firma vigente</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Gratuito</span>
							<button id="btn-sat-tramite" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</button>
						</div>
					</div>

					<!-- Card 3: Pasaportes (SRE) -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="sre pasaporte mexicano cita relaciones exteriores viaje internacional">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">RELACIONES EXTERIORES (SRE)</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: 1 día (Cita)</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Trámite de Pasaporte Mexicano</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Pre-cotejo de requisitos y solicitud de cita oficial para la emisión de pasaporte por primera vez o renovación en las delegaciones de Yucatán.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• Acta de nacimiento certificada • INE vigente • Pago de derechos</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Estatal + Federal</span>
							<a href="/ciudadano/tramite?id=pasaporte" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 4: INE / Registro Civil (CURP y Actas) -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="ine registro civil curp actas nacimiento defuncion matrimonio yucatan copias">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">REGISTRO CIVIL / INE</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: Inmediato</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">CURP y Actas Certificadas</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Búsqueda y expedición oficial de la clave CURP y copias certificadas del acta de nacimiento, matrimonio o actas registrales del estado civil de las personas.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• CURP o datos registrales completos • Pago por copia</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Gratuito / Variable</span>
							<a href="/ciudadano/tramite?id=ine" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 5: Tarjeta Va y Ven -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="tarjeta va y ven estudiante transporte publico movilidad camion pasaje tarifa social">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">MOVILIDAD</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: Inmediato</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Tarjeta Va y Ven (Estudiante)</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Solicitud o renovación de tarifa social para transporte público.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• Identificación oficial • Constancia de estudios vigente • Comprobante de domicilio reciente</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Gratuito</span>
							<a href="/ciudadano/tramite?id=vayeven" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 6: Antecedentes -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="constancia antecedentes no penales seguridad trabajo empleo fiscalia policiaco policia yucatan">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">SEGURIDAD</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: 24 a 48 hrs</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Constancia de Antecedentes No Penales</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Documento oficial para fines laborales.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• Identificación oficial (INE) • CURP certificado • Acta de nacimiento reciente</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: $86.00 MXN</span>
							<a href="/ciudadano/tramite?id=antecedentes" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 7: Licencia Municipal -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="licencia funcionamiento municipal comercio negocio apertura local economia ayuntamiento">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">ECONOMÍA</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: 3 días hábiles</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Licencia de Funcionamiento Municipal</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Aviso de apertura para comercios y oficinas de bajo riesgo.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• Identificación oficial • Comprobante de domicilio del local • Croquis de ubicación</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: $586.55 MXN</span>
							<a href="/ciudadano/tramite?id=licencia_municipal" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 8: Paneles Solares -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="subsidio paneles solares apoyo social sustentable casa luz cfe energia solar ecologico">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">APOYO SOCIAL</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: Sujeto a convocatoria</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Subsidio de Paneles Solares</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Programa de apoyo a la vivienda sustentable.
							</p>
							<div class="mt-4 space-y-1">
								<h4 class="text-[10px] font-bold text-slate-700 uppercase tracking-wider font-display">Requisitos clave:</h4>
								<p class="text-[11px] text-slate-500">• CURP oficial • Recibo de luz CFE • Identificación oficial del propietario</p>
							</div>
						</div>
						<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">
							<span class="text-xs font-bold text-yuc-gold-dark font-display">Costo: Gratuito</span>
							<a href="/ciudadano/tramite?id=paneles_solares" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg transition-colors font-display shadow-sm">
								Iniciar Trámite
							</a>
						</div>
					</div>

					<!-- Card 9: Acta Digital -->
					<div class="catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between" data-title="copia certificada acta de nacimiento digital registro civil renapo curp yucatan">
						<div>
							<div class="flex justify-between items-start gap-4">
								<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase font-display">REGISTRO CIVIL</span>
								<span class="text-xs text-slate-500 font-medium">Resolución: Inmediato</span>
							</div>
							<h3 class="text-lg font-bold text-slate-800 mt-3 font-display">Copia Certificada de Acta de Nacimiento (Digital)</h3>
							<p class="text-xs text-slate-650 mt-2 leading-relaxed">
								Obtención instantánea de copia certificada. Al contar con tu Expediente Digital Único, el sistema valida tu CURP ante RENAPO y emite el PDF firmado electrónicamente sin intervención humana.
							</p>
