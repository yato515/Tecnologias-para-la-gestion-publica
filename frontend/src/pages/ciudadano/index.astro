	<script is:inline define:vars={{ API_URL }}>
		// ── Helpers ──────────────────────────────────────────────────────────────
		function safeJSONParse(key, fallback) {
			if (fallback === undefined) fallback = null;
			try {
				const value = localStorage.getItem(key);
				if (!value || value === 'undefined' || value === 'null') return fallback;
				return JSON.parse(value);
			} catch (err) {
				localStorage.removeItem(key);
				return fallback;
			}
		}

		const DEFAULT_DOSSIER = [
			{ id: 'ine',      name: 'Identificación Oficial Vigente (INE)', file: '', status: 'Pendiente', date: '-' },
			{ id: 'domicilio',name: 'Comprobante de Domicilio',             file: '', status: 'Pendiente', date: '-' },
			{ id: 'acta',     name: 'Acta de Nacimiento Certificada',       file: '', status: 'Pendiente', date: '-' },
			{ id: 'curp',     name: 'Cédula CURP Oficial',                  file: '', status: 'Pendiente', date: '-' }
		];

		function getDossier() {
			const parsed = safeJSONParse('civicflow_dossier', null);
			if (Array.isArray(parsed) && parsed.length > 0) return parsed;
			localStorage.setItem('civicflow_dossier', JSON.stringify(DEFAULT_DOSSIER));
			return DEFAULT_DOSSIER;
		}

		function getRequests() {
			const parsed = safeJSONParse('civicflow_requests', []);
			return Array.isArray(parsed) ? parsed : [];
		}

		function refreshExpedienteToken() {
			var currentToken = 'TK-' + Math.floor(100000 + Math.random() * 900000);
			localStorage.setItem('jwt_token', currentToken);
			var tokDict = safeJSONParse('civicflow_tokens', {});
			tokDict[currentToken] = {};
			getDossier().forEach(function(d) { if (d.status === 'Cargado') tokDict[currentToken][d.id] = d.file; });
			localStorage.setItem('civicflow_tokens', JSON.stringify(tokDict));
			var tEl = document.getElementById('lbl-token');
			if (tEl) { tEl.textContent = currentToken; tEl.title = 'Ver completo (Haga clic)'; }
			return currentToken;
		}

		function renderDossier() {
			const grid = document.getElementById('dossier-grid');
			if (!grid) return;
			const dossier = getDossier();
			grid.innerHTML = '';
			let loadedCount = 0;

			dossier.forEach(function(doc) {
				try {
					const isLoaded = doc.status === 'Cargado';
					if (isLoaded) loadedCount++;

					const card = document.createElement('div');
					card.className = 'bg-white border border-slate-200 rounded-xl p-5 flex flex-col justify-between h-44 shadow-sm';

					const statusBadge = isLoaded
						? '<span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-800 border border-emerald-250 font-bold text-[9px] uppercase tracking-wide font-display">✓ Cargado</span>'
						: '<span class="px-2 py-0.5 rounded bg-amber-50 text-amber-800 border border-amber-250 font-bold text-[9px] uppercase tracking-wide font-display">Pendiente</span>';

					const actionButtons = isLoaded
						? '<div class="flex justify-between items-center gap-3 w-full">' +
							'<div class="text-left">' +
								'<p class="text-[10px] text-slate-700 font-mono truncate max-w-[150px]" title="' + doc.file + '">' + doc.file + '</p>' +
								'<p class="text-[9px] text-slate-500">Fecha: ' + doc.date + '</p>' +
							'</div>' +
							'<div class="flex gap-2">' +
								'<button data-action="dl" class="px-2.5 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[10px] font-bold rounded border border-slate-200 font-display transition-colors">Descargar</button>' +
								'<button data-action="repl" class="px-2.5 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[10px] font-bold rounded border border-slate-200 font-display transition-colors">Reemplazar</button>' +
							'</div>' +
						'</div>'
						: '<div class="relative flex items-center justify-center border-2 border-dashed border-slate-200 hover:border-yuc-green hover:bg-yuc-green/5 rounded-lg p-4 cursor-pointer text-center h-16 w-full transition-colors">' +
							'<input type="file" accept=".pdf,application/pdf" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full" />' +
							'<span class="text-xs font-bold text-slate-550 font-display pointer-events-none">Subir Archivo (PDF)</span>' +
						'</div>';

					card.innerHTML =
						'<div class="flex justify-between items-start gap-4">' +
							'<h4 class="font-bold text-xs text-slate-800 font-display">' + doc.name + '</h4>' +
							statusBadge +
						'</div>' +
						'<div class="pt-4 border-t border-slate-100 mt-4 flex items-center justify-center w-full">' +
							actionButtons +
						'</div>';

					grid.appendChild(card);

					if (isLoaded) {
						var dlBtn = card.querySelector('[data-action="dl"]');
						if (dlBtn) dlBtn.addEventListener('click', function() {
							var csv = 'data:text/plain;charset=utf-8,CIVICFLOW - GOBIERNO DE YUCATAN\n' +
								'DOCUMENTO: ' + doc.name + '\nArchivo: ' + doc.file + '\nFecha: ' + doc.date + '\n' +
								'Sello: CF-DOC-YUC-' + doc.id.toUpperCase() + '-2026\n';
							var a = document.createElement('a');
							a.href = encodeURI(csv);
							a.download = doc.file;
							document.body.appendChild(a); a.click(); document.body.removeChild(a);
							window.showToast('Descargando ' + doc.name, 'success');
						});

						var replBtn = card.querySelector('[data-action="repl"]');
						if (replBtn) replBtn.addEventListener('click', function() {
							var updated = getDossier().map(function(d) {
								return d.id === doc.id ? Object.assign({}, d, { status: 'Pendiente', file: '' }) : d;
							});
							localStorage.setItem('civicflow_dossier', JSON.stringify(updated));
							refreshExpedienteToken();
							renderDossier();
							window.showToast('Carga restablecida. Seleccione nuevo archivo.', 'info');
						});
					} else {
						var inp = card.querySelector('input[type="file"]');
						if (inp) inp.addEventListener('change', function(e) {
							var f = e.target.files[0];
							if (!f) return;
							if (f.type !== 'application/pdf' && !f.name.toLowerCase().endsWith('.pdf')) {
								window.showToast('Solo se permiten archivos PDF', 'error');
								e.target.value = '';
								return;
							}
							var curp = localStorage.getItem('citizen_curp') || 'XMOCK';
							var uniqueName = curp + '_' + doc.id + '_' + Date.now() + '.pdf';
							var today = new Date().toISOString().split('T')[0];
							var updated = getDossier().map(function(d) {
								return d.id === doc.id ? Object.assign({}, d, { status: 'Cargado', file: uniqueName, date: today }) : d;
							});
							localStorage.setItem('civicflow_dossier', JSON.stringify(updated));
							refreshExpedienteToken();
							renderDossier();
							
							// Guardar en la Base de Datos (Hackathon: enviamos solo el nombre del archivo)
							var ciudadanoId = localStorage.getItem('citizen_id');
							if (ciudadanoId) {
								var columnMap = {
									'ine': 'identificacion_oficial_vigente_ine',
									'domicilio': 'comprobante_de_domicilio',
									'acta': 'acta_de_nacimiento_certificada',
									'curp': 'cedula_curp_oficial'
								};
								var bodyPayload = {};
								bodyPayload[columnMap[doc.id]] = uniqueName;
								
								fetch(API_URL + '/api/expedientes/' + ciudadanoId, {
									method: 'PUT',
									headers: { 'Content-Type': 'application/json' },
									body: JSON.stringify(bodyPayload)
								}).catch(function(err) { console.error('Error guardando archivo en BD:', err); });
							}

							window.showToast('Documento ' + doc.name + ' subido exitosamente', 'success');
						});
					}
				} catch (err) {
					console.error('[CivicFlow] Error en tarjeta:', doc && doc.id, err);
				}
			});

			// Progress
			var pct = Math.round((loadedCount / DEFAULT_DOSSIER.length) * 100);
			var lblP = document.getElementById('lbl-dossier-progress');
			var barP = document.getElementById('bar-dossier-progress');
			if (lblP) lblP.textContent = pct + '%';
			if (barP) barP.style.width = pct + '%';

			// Token auto-generation when all docs uploaded
			if (loadedCount === DEFAULT_DOSSIER.length) {
				var currentToken = localStorage.getItem('jwt_token');
				if (!currentToken || currentToken === 'N/A' || currentToken === 'mock-jwt-token-demo') {
					refreshExpedienteToken();
					window.showToast('¡Expediente completo! Token generado.', 'success');
				}
			}
		}

		// ── Auth guard ────────────────────────────────────────────────────────────
		if (localStorage.getItem('citizen_logged') !== 'true') {
			window.location.href = '/ciudadano/login';
		} else {
				// Limpiar datos mock/seed (migración única)
			var rawSd = localStorage.getItem('civicflow_dossier');
			if (rawSd) {
				try {
					var _sd = JSON.parse(rawSd);
					if (Array.isArray(_sd) && _sd.some(function(d) {
						return d && (d.file === 'ine_ciudadano_yuc.pdf' || d.file === 'comprobante_luz_merida.pdf');
					})) localStorage.removeItem('civicflow_dossier');
				} catch(e) { localStorage.removeItem('civicflow_dossier'); }
			}
			var rawSr = localStorage.getItem('civicflow_requests');
			if (rawSr) {
				try {
					var _sr = JSON.parse(rawSr);
					if (Array.isArray(_sr) && _sr.some(function(r) { return r && r.folio === 'TRM-2026-00104'; }))
						localStorage.removeItem('civicflow_requests');
				} catch(e) {}
			}

			// Header info
			document.getElementById('lbl-curp').textContent = localStorage.getItem('citizen_curp') || 'N/A';
			document.getElementById('lbl-email').textContent = localStorage.getItem('citizen_email') || 'N/A';
			var token = localStorage.getItem('jwt_token');
			var tokenEl = document.getElementById('lbl-token');
			if (token && token !== 'mock-jwt-token-demo') {
				tokenEl.textContent = token;
				tokenEl.title = 'Ver completo (Haga clic)';
			} else {
				tokenEl.textContent = 'N/A (No generado)';
				tokenEl.title = 'Sube tus documentos en tu expediente para generar tu token';
			}
			tokenEl.addEventListener('click', function() {
				var t = localStorage.getItem('jwt_token');
				alert(t && t !== 'mock-jwt-token-demo'
					? 'Token de Expediente Completo:\n\n' + t
					: 'No tienes un token aún. Se generará al completar tu expediente digital.');
			});

			// ── Tabs ─────────────────────────────────────────────────────────────
			var tabCatalog  = document.getElementById('tab-btn-catalog');
			var tabInbox    = document.getElementById('tab-btn-inbox');
			var tabFolder   = document.getElementById('tab-btn-folder');
			var contCatalog = document.getElementById('tab-content-catalog');
			var contInbox   = document.getElementById('tab-content-inbox');
			var contFolder  = document.getElementById('tab-content-folder');

			var ACTIVE   = 'pb-4 px-1 text-sm font-extrabold border-b-2 border-yuc-green text-yuc-green focus:outline-none flex items-center gap-2';
			var INACTIVE = 'pb-4 px-1 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-800 focus:outline-none flex items-center gap-2 relative';

			function activateTab(tab) {
				tabCatalog.className = INACTIVE; tabInbox.className = INACTIVE; tabFolder.className = INACTIVE;
				contCatalog.classList.add('hidden'); contInbox.classList.add('hidden'); contFolder.classList.add('hidden');
				if (tab === 'catalog') { tabCatalog.className = ACTIVE; contCatalog.classList.remove('hidden'); }
				else if (tab === 'inbox')  { tabInbox.className = ACTIVE + ' relative'; contInbox.classList.remove('hidden'); renderInbox(); }
				else if (tab === 'folder') { tabFolder.className = ACTIVE; contFolder.classList.remove('hidden'); renderDossier(); }
			}

			tabCatalog.addEventListener('click', function() { activateTab('catalog'); });
			tabInbox.addEventListener('click',   function() { activateTab('inbox'); });
			tabFolder.addEventListener('click',  function() { activateTab('folder'); });

			// Activar tab por URL param
			var urlTab = new URLSearchParams(window.location.search).get('tab');
			if (urlTab === 'folder') activateTab('folder');
			else if (urlTab === 'inbox') activateTab('inbox');

			// ── Catálogo API ──────────────────────────────────────────────────────
			fetch(API_URL + '/api/tramites/catalogo', { headers: { 'Authorization': 'Bearer ' + token } })
				.then(function(r) {
					if (r.status === 401 || r.status === 403) { localStorage.clear(); window.location.href = '/ciudadano/login'; return null; }
					return r.json();
				})
				.then(function(json) {
					if (!json || !json.success || !json.data || !json.data.length) return;
					var grid = document.getElementById('catalog-grid');
					json.data.forEach(function(t) {
						var card = document.createElement('div');
						card.className = 'catalog-card bg-white border border-slate-200 hover:border-yuc-green/30 rounded-xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col justify-between';
						card.setAttribute('data-title', (t.nombre || '').toLowerCase());
						card.innerHTML =
							'<div><div class="flex justify-between items-start gap-4">' +
								'<span class="px-2 py-0.5 rounded bg-yuc-green/10 text-yuc-green font-bold text-[10px] uppercase">' + (t.dependencia && t.dependencia.nombre ? t.dependencia.nombre : 'Dependencia') + '</span>' +
								'<span class="text-xs text-slate-500 font-medium">Resolución: ' + (t.plazo_dias_habiles ? t.plazo_dias_habiles + ' días' : 'Variable') + '</span>' +
							'</div><h3 class="text-lg font-bold text-slate-800 mt-3 font-display">' + t.nombre + '</h3>' +
							'<p class="text-xs text-slate-500 mt-2 leading-relaxed">' + (t.descripcion || '') + '</p></div>' +
							'<div class="pt-6 border-t border-slate-100 mt-6 flex justify-between items-center">' +
								'<span class="text-xs font-bold text-yuc-gold">Costo: ' + (t.costo_referencia || 'Consultar') + '</span>' +
								'<a href="/ciudadano/tramite?id=' + t.id + '" class="px-4 py-2 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-bold rounded-lg border border-yuc-gold/20 transition-all shadow-sm">Iniciar Trámite</a>' +
							'</div>';
						grid.prepend(card);
					});
				})
				.catch(function() {});

			// ── Búsqueda catálogo ─────────────────────────────────────────────────
			var searchInput = document.getElementById('txt-search');
			var noResults   = document.getElementById('no-results-msg');
			searchInput.addEventListener('input', function() {
				var q = searchInput.value.toLowerCase().trim();
				var visible = 0;
				document.querySelectorAll('.catalog-card').forEach(function(c) {
					var match = c.textContent.toLowerCase().includes(q) || (c.getAttribute('data-title') || '').includes(q);
					c.classList.toggle('hidden', !match);
					if (match) visible++;
				});
				noResults.classList.toggle('hidden', visible > 0);
			});
			document.getElementById('btn-clear-search').addEventListener('click', function() {
				searchInput.value = '';
				searchInput.dispatchEvent(new Event('input'));
			});

			// ── User Info Logic ───────────────────────────────────────────────────
			var inputDob = document.getElementById('input-dob');
			var inputPob = document.getElementById('input-pob');
			var btnSaveUserInfo = document.getElementById('btn-save-user-info');
			if (inputDob && inputPob && btnSaveUserInfo) {
				inputDob.value = localStorage.getItem('citizen_dob') || '';
				inputPob.value = localStorage.getItem('citizen_pob') || '';
				btnSaveUserInfo.addEventListener('click', function() {
					localStorage.setItem('citizen_dob', inputDob.value);
					localStorage.setItem('citizen_pob', inputPob.value);
					refreshExpedienteToken();
					
					var ciudadanoId = localStorage.getItem('citizen_id');
					if (ciudadanoId) {
						var bodyPayload = {
							fecha_de_nacimiento: inputDob.value || null,
							lugar_de_nacimiento: inputPob.value || null
						};
						fetch(API_URL + '/api/expedientes/' + ciudadanoId, {
							method: 'PUT',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(bodyPayload)
						}).catch(function(err) { console.error('Error guardando info en BD:', err); });
					}

					window.showToast('Información guardada y token actualizado', 'success');
				});
			}

			// ── ZIP download ──────────────────────────────────────────────────────
			document.getElementById('btn-download-dossier-zip').addEventListener('click', async function() {
				var btn = this;
				var originalText = btn.innerHTML;
				btn.innerHTML = '<span>Generando ZIP...</span>';
				btn.disabled = true;

				if (typeof JSZip === 'undefined') {
					await new Promise(function(res, rej) {
						var script = document.createElement('script');
						script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
						script.onload = res;
						script.onerror = rej;
						document.head.appendChild(script);
					});
				}

				var zip = new JSZip();
				var dossier = getDossier();
				var dob = localStorage.getItem('citizen_dob') || 'No registrada';
				var pob = localStorage.getItem('citizen_pob') || 'No registrado';
				var curp = localStorage.getItem('citizen_curp') || 'N/A';
				var email = localStorage.getItem('citizen_email') || 'N/A';

				var infoTxt = '=====================================================\n' +
					'CIVICFLOW - GOBIERNO DEL ESTADO DE YUCATAN\nEXPEDIENTE DIGITAL UNICO\n' +
					'=====================================================\n\n' +
					'CURP: ' + curp + '\n' +
					'Correo: ' + email + '\n' +
					'Fecha de Nacimiento: ' + dob + '\n' +
					'Lugar de Nacimiento: ' + pob + '\n' +
					'Fecha de descarga: ' + new Date().toLocaleString() + '\n\nDOCUMENTOS:\n' +
					dossier.map(function(d) {
						return '- ' + d.name + ': ' + (d.status === 'Cargado' ? d.file + ' (' + d.date + ')' : 'PENDIENTE');
					}).join('\n');

				zip.file('informacion_ciudadano.txt', infoTxt);

				dossier.forEach(function(d) {
					if (d.status === 'Cargado') {
						var fileContent = 'CIVICFLOW - GOBIERNO DE YUCATAN\n' +
							'DOCUMENTO: ' + d.name + '\nArchivo: ' + d.file + '\nFecha: ' + d.date + '\n' +
							'Sello: CF-DOC-YUC-' + d.id.toUpperCase() + '-2026\n';
						zip.file(d.file, fileContent);
					}
				});

				zip.generateAsync({type:"blob"}).then(function(content) {
					var url = URL.createObjectURL(content);
					var a = document.createElement('a');
					a.href = url;
					a.download = 'expediente_' + curp + '.zip';
					document.body.appendChild(a);
					a.click();
					document.body.removeChild(a);
					URL.revokeObjectURL(url);
					
					btn.innerHTML = originalText;
					btn.disabled = false;
					window.showToast('Expediente completo (ZIP) descargado exitosamente', 'success');
				});
			});

			// ── renderInbox ───────────────────────────────────────────────────────
			function renderInbox() {
				var tbody   = document.getElementById('inbox-tbody');
				var emptyMsg = document.getElementById('inbox-empty-msg');
				var badge   = document.getElementById('badge-inbox-count');
				var citizenId = localStorage.getItem('citizen_id');

				var apiCall = citizenId
					? fetch(API_URL + '/api/tramites/solicitudes/' + citizenId, { headers: { 'Authorization': 'Bearer ' + token } })
						.then(function(r) {
							if (r.status === 401 || r.status === 403) { localStorage.clear(); window.location.href = '/ciudadano/login'; return null; }
							return r.json();
						})
						.then(function(json) {
							if (json && json.success && Array.isArray(json.data)) {
								return json.data.map(function(s) { return {
									folio: s.folio || s.id,
									name:  (s.tramite && s.tramite.nombre) || (s.campos_respuesta && s.campos_respuesta.tramite_nombre_fallback) || 'Trámite',
									dept:  (s.dependencia && s.dependencia.nombre) || (s.campos_respuesta && s.campos_respuesta.dependencia_nombre_fallback) || '-',
									date:  (s.created_at || '').split('T')[0],
									status: s.estado || 'recibido'
								}; });
							}
							return [];
						}).catch(function() { return []; })
					: Promise.resolve([]);

				apiCall.then(function(apiRequests) {
					var stored = getRequests();
					var requests = apiRequests.length > 0 ? apiRequests : stored;
					tbody.innerHTML = '';
					if (!requests.length) {
						emptyMsg.classList.remove('hidden');
						if (badge) badge.classList.add('hidden');
						return;
					}
					emptyMsg.classList.add('hidden');
					if (badge) { badge.classList.remove('hidden'); badge.textContent = requests.length; }

					var STATUS = {
						'En revisión': 'bg-amber-500/10 text-amber-500 border border-amber-500/20',
						'Aprobado': 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20',
						'Documentación incompleta': 'bg-orange-500/10 text-orange-500 border border-orange-500/20',
						'Rechazado': 'bg-red-500/10 text-red-500 border border-red-500/20',
						'Recibido': 'bg-yuc-green/10 text-yuc-green border border-yuc-green/20'
					};
					requests.slice().reverse().forEach(function(req) {
						var bc = STATUS[req.status] || 'bg-slate-100 text-slate-700';
						var tr = document.createElement('tr');
						tr.className = 'hover:bg-slate-50 border-b border-slate-100 transition-colors';
						tr.innerHTML =
							'<td class="px-6 py-4 font-mono font-bold text-slate-800">' + req.folio + '</td>' +
							'<td class="px-6 py-4 font-semibold text-slate-700">' + req.name + '</td>' +
							'<td class="px-6 py-4 text-xs text-slate-500">' + req.dept + '</td>' +
							'<td class="px-6 py-4 text-xs text-slate-500">' + req.date + '</td>' +
							'<td class="px-6 py-4"><span class="px-2.5 py-1 rounded-full text-xs font-bold ' + bc + '">' + req.status + '</span></td>' +
							'<td class="px-6 py-4 text-right"><a href="/ciudadano/tracker?folio=' + req.folio + '" class="px-3.5 py-1.5 bg-slate-50 hover:bg-yuc-green hover:text-white text-slate-700 border border-slate-200 text-xs font-extrabold rounded-lg transition-all inline-flex items-center gap-1 font-display">Rastrear</a></td>';
						tbody.appendChild(tr);
					});
				});
			}

			document.getElementById('btn-refresh-inbox').addEventListener('click', function() {
				renderInbox(); window.showToast('Bandeja actualizada', 'success');
			});

			// Logout
			document.getElementById('btn-logout').addEventListener('click', function() {
				localStorage.clear();
				window.showToast('Sesión cerrada', 'info');
				setTimeout(function() { window.location.href = '/ciudadano/login'; }, 600);
			});

			// SAT modal (elementos opcionales — el modal HTML puede no existir)
			var satModal       = document.getElementById('sat-rfc-modal');
			var btnSat         = document.getElementById('btn-sat-tramite');
			var btnCloseSat    = document.getElementById('btn-close-sat-modal');
			var satCloseBg     = document.getElementById('sat-modal-close-bg');
			var btnSaveRfc     = document.getElementById('btn-save-rfc');
			var rfcInput       = document.getElementById('sat-rfc-input');
			var btnGoToSat     = document.getElementById('btn-go-to-sat');
			var storedRfc      = localStorage.getItem('citizen_rfc');
			if (rfcInput && storedRfc) rfcInput.value = storedRfc;

			function openSatModal()  { if (satModal) satModal.classList.remove('hidden'); }
			function closeSatModal() { if (satModal) satModal.classList.add('hidden'); }

			if (btnSat) btnSat.addEventListener('click', function() {
				localStorage.getItem('citizen_rfc') ? window.location.href = '/ciudadano/tramite?id=sat' : (openSatModal(), window.showToast('Se requiere RFC para trámites fiscales', 'warning'));
			});
			if (btnCloseSat) btnCloseSat.addEventListener('click', closeSatModal);
			if (satCloseBg)  satCloseBg.addEventListener('click', closeSatModal);
			if (btnSaveRfc)  btnSaveRfc.addEventListener('click', function() {
				if (!rfcInput) return;
				var rfc = rfcInput.value.trim().toUpperCase();
				if (rfc.length < 12 || rfc.length > 13) { window.showToast('RFC debe tener 12 o 13 caracteres', 'error'); return; }
				localStorage.setItem('citizen_rfc', rfc);
				window.showToast('RFC configurado exitosamente', 'success');
				closeSatModal();
				setTimeout(function() { window.location.href = '/ciudadano/tramite?id=sat'; }, 600);
			});
			if (btnGoToSat) btnGoToSat.addEventListener('click', closeSatModal);

			// Badge de bandeja al cargar
			var initReqs = getRequests();
			var initBadge = document.getElementById('badge-inbox-count');
			if (initReqs.length > 0 && initBadge) {
				initBadge.textContent = initReqs.length;
				initBadge.classList.remove('hidden');
				initBadge.classList.add('inline-flex');
			}
		}
	</script>
</Layout>
