---
import Layout from '../../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Registro y Consentimiento de Privacidad - Portal Ciudadano">
	<div class="min-h-[calc(100vh-13rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50 relative overflow-hidden">
		
		<!-- Decorative green and gold glow effects -->
		<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-yuc-green/5 rounded-full blur-3xl pointer-events-none"></div>
		<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-yuc-gold/5 rounded-full blur-3xl pointer-events-none"></div>

		<div class="max-w-2xl w-full space-y-8 bg-white p-8 sm:p-10 rounded-2xl border border-slate-200 shadow-xl relative z-10 border-t-4" style="border-top-color: #005c42;">
			
			<div class="text-center">
				<div class="mx-auto w-12 h-12 rounded-xl bg-yuc-green/10 text-yuc-green flex items-center justify-center mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
					</svg>
				</div>
				<h2 class="text-2xl font-bold text-slate-800 font-display">Registro Ciudadano</h2>
				<p class="mt-2 text-xs text-slate-500">
					Cree su cuenta única para la gestión y tramitación automatizada en el Estado de Yucatán.
				</p>
			</div>

			<form class="mt-8 space-y-6" id="register-form">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					
					<!-- Left Side: Basic Info Fields -->
					<div class="space-y-4">
						<h3 class="text-xs font-extrabold text-yuc-green uppercase tracking-wider border-b border-slate-200 pb-2 font-display">Información de Cuenta</h3>
						
						<!-- CURP Field -->
						<div>
							<label for="curp" class="block text-[10px] font-bold text-slate-700 uppercase tracking-wider mb-1">CURP (Clave Única de Registro) *</label>
							<input 
								id="curp" 
								name="curp" 
								type="text" 
								required 
								maxlength="18"
								class="block w-full px-4 py-2.5 rounded-xl border border-slate-300 bg-white text-slate-900 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm uppercase font-mono placeholder-slate-400"
								placeholder="AAAA000000XXXXXX00"
							/>
							<p id="curp-error" class="mt-1 text-[11px] text-red-500 font-semibold hidden"></p>
						</div>

						<!-- Fullname Field -->
						<div>
							<label for="fullname" class="block text-[10px] font-bold text-slate-700 uppercase tracking-wider mb-1 font-display">Nombre Completo *</label>
							<input id="fullname" name="fullname" type="text" required 
								class="block w-full px-4 py-2.5 rounded-xl border border-slate-300 bg-white text-slate-900 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm placeholder-slate-400"
								placeholder="Escriba su nombre completo" />
						</div>
						<!-- Email Field -->
						<div>
							<label for="email" class="block text-[10px] font-bold text-slate-700 uppercase tracking-wider mb-1 font-display">Correo Electrónico *</label>
							<input id="email" name="email" type="email" required 
								class="block w-full px-4 py-2.5 rounded-xl border border-slate-300 bg-white text-slate-900 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm placeholder-slate-400"
								placeholder="correo@ejemplo.com" />
						</div>
						<!-- Password Field -->
						<div>
							<label for="password" class="block text-[10px] font-bold text-slate-700 uppercase tracking-wider mb-1 font-display">Contraseña *</label>
							<input id="password" name="password" type="password" required 
								class="block w-full px-4 py-2.5 rounded-xl border border-slate-300 bg-white text-slate-900 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm placeholder-slate-400"
								placeholder="Mínimo 6 caracteres" />
						</div>

					</div>

					<!-- Right Side: Privacy Agreement Policy -->
					<div class="space-y-4 flex flex-col">
						<h3 class="text-xs font-extrabold text-yuc-green uppercase tracking-wider border-b border-slate-200 pb-2 font-display">Acuerdo de Privacidad Estatal</h3>
						
						<!-- Large Scrollable Policy Area -->
						<div class="flex-grow bg-slate-50 rounded-xl p-4 border border-slate-200 text-[11px] leading-relaxed text-slate-600 overflow-y-scroll max-h-[220px] select-text">
							<p class="font-bold text-yuc-green mb-2 font-display">AVISO DE PRIVACIDAD INTEGRAL - PLATAFORMA CIVICFLOW</p>
							<p class="mb-3">El Gobierno del Estado de Yucatán, a través de la Oficialía Mayor y las dependencias estatales participantes (incluyendo la Agencia de Administración Fiscal del Estado de Yucatán (AAFY/SAT Estatal), la Secretaría de Seguridad Pública (SSP), el Registro Civil y la Dirección de Catastro), es el responsable del tratamiento de los datos personales que proporcione.</p>
							<p class="mb-3"><strong class="text-yuc-gold">Intercambio de Datos Interdependencias:</strong> Al registrarse e iniciar cualquier trámite en esta plataforma, usted autoriza de forma expresa, plena e irrevocable al sistema CivicFlow para realizar el cruce automático de datos con las bases oficiales del Registro Nacional de Población (RENAPO), el Instituto Nacional Electoral (INE), la Secretaría de Seguridad Pública, y el Servicio de Administración Tributaria (SAT). Esto faculta a los revisores a cotejar la validez de su CURP, historial de licencias de conducir, registros catastrales y estatus de RFC directamente desde los sistemas de cada dependencia sin necesidad de presentar duplicados físicos.</p>
							<p class="mb-3">Los datos personales recolectados serán protegidos en los términos de la Ley General de Protección de Datos Personales en Posesión de Sujetos Obligados y la legislación del Estado de Yucatán. Se utilizarán únicamente para verificar su identidad y agilizar la resolución de sus trámites.</p>
							<p class="font-bold text-yuc-gold font-display">Derechos ARCO:</p>
							<p>Usted podrá ejercer sus derechos de acceso, rectificación, cancelación y oposición de sus datos personales a través del portal de transparencia oficial o de forma directa en las oficinas centrales de CivicFlow en Mérida, Yucatán.</p>
						</div>

						<!-- Mandatory Checkbox -->
						<div class="flex items-start">
							<input id="privacy-consent" name="privacy-consent" type="checkbox"
								class="h-4.5 w-4.5 text-yuc-green focus:ring-yuc-green bg-white border-slate-300 rounded mt-0.5" 
							/>
							<label for="privacy-consent" class="ml-2 text-[10.5px] leading-tight text-slate-600 font-medium">
								<strong class="text-yuc-green font-display">Acepto expresamente el intercambio de mis datos</strong> entre dependencias del Gobierno de Yucatán para la validación automática de mis trámites. *
							</label>
						</div>
					</div>

				</div>

				<div class="pt-6 border-t border-slate-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
					<span class="text-[10px] text-slate-400 font-semibold">* Campos obligatorios</span>
					<div class="flex gap-3">
						<a href="/ciudadano/login" class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold rounded-xl transition-colors border border-slate-300 text-center font-display">
							Ya tengo cuenta
						</a>
						<button type="submit" class="px-6 py-2.5 bg-yuc-green hover:bg-yuc-green-light text-white text-xs font-extrabold rounded-xl shadow-md transition-colors border border-yuc-gold/20 font-display">
							Crear Cuenta Ciudadana
						</button>
					</div>
				</div>

			</form>

		</div>
	</div>

	<script is:inline define:vars={{ API_URL }}>
		const form = document.getElementById('register-form');
		const curpInput = document.getElementById('curp');
		const curpError = document.getElementById('curp-error');
		const consentCheck = document.getElementById('privacy-consent');

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const curp = curpInput.value.trim().toUpperCase();
			const email = document.getElementById('email').value.trim();
			const fullname = document.getElementById('fullname').value.trim();

			curpError.classList.add('hidden');

			const curpRegex = /^[A-Z]{4}\d{6}[HM][A-Z]{5}[A-Z0-9]\d$/;
			if (curp.length !== 18) {
				curpError.textContent = "El CURP debe tener exactamente 18 caracteres.";
				curpError.classList.remove('hidden');
				window.showToast("Corrija el CURP para continuar", "error");
				return;
			}
			if (!curpRegex.test(curp)) {
				curpError.textContent = "Formato de CURP inválido (Ej: AAAA000000HDFXX000).";
				curpError.classList.remove('hidden');
				window.showToast("CURP con formato inválido", "error");
				return;
			}
			if (!consentCheck.checked) {
				window.showToast("Debe aceptar expresamente el intercambio de datos gubernamentales.", "error");
				return;
			}

			// Registrar en el backend
			try {
				const res = await fetch(`${API_URL}/api/users/register`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ curp, email, nombre_completo: fullname })
				});
				const json = await res.json();
				if (json.success) {
					window.showToast("¡Registro completado! Redirigiendo al login...", "success");
					setTimeout(() => { window.location.href = '/ciudadano/login'; }, 1200);
					return;
				} else {
					window.showToast(json.message || "Error al registrar usuario", "error");
					return;
				}
			} catch (_) {
				// Backend no disponible, continúa con sesión local
				localStorage.setItem('citizen_curp', curp);
				localStorage.setItem('citizen_email', email);
				localStorage.setItem('citizen_fullname', fullname);
				localStorage.setItem('citizen_logged', 'true');
				window.showToast("¡Registro completado (Modo Demo)!", "success");
				setTimeout(() => { window.location.href = '/ciudadano'; }, 800);
			}
		});
	</script>
</Layout>
