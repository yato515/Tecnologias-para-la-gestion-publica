---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Iniciar Solicitud de Trámite">
	
	<!-- Top Banner -->
	<section class="bg-yuc-green text-white py-8 transition-colors border-b border-yuc-gold/30">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
			<div>
				<a href="/ciudadano" class="text-xs font-bold text-yuc-gold hover:underline flex items-center gap-1.5 font-display">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
					</svg>
					<span>Volver al Catálogo</span>
				</a>
				<h1 id="lbl-tramite-title" class="text-2xl sm:text-3xl font-black font-display mt-2">Cargando Trámite...</h1>
				<p id="lbl-tramite-dept" class="text-slate-200 text-xs mt-1">Dependencia: ...</p>
			</div>
		</div>
	</section>

	<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		
		<!-- Main Form Card (Estilo Institucional / Oriéntate) -->
		<div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
			
			<div class="p-8 space-y-8">
				
				<div class="text-center space-y-2">
					<h2 class="text-2xl font-bold text-yuc-green-dark font-display">Validación de Requisitos</h2>
					<p class="text-sm text-slate-500 max-w-lg mx-auto">
						Para agilizar su solicitud y evitar que acuda presencialmente, utilizaremos su Expediente Digital Único. 
						Proporcione su Token de Autenticación para continuar.
					</p>
				</div>

				<form id="token-form" class="space-y-6 max-w-xl mx-auto border border-slate-100 p-6 rounded-lg bg-slate-50">
					
					<!-- Radio Buttons: ¿Tienes tu Token? -->
					<div class="space-y-3 text-center border-b border-slate-200 pb-6">
						<p class="text-sm font-bold text-slate-800 font-display">¿Cuentas con tu Token de Expediente Digital?</p>
						<div class="flex items-center justify-center gap-8 mt-2">
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="radio" name="hasToken" value="yes" checked class="w-4 h-4 text-yuc-green focus:ring-yuc-green border-slate-300">
								<span class="text-sm font-semibold text-slate-700">Sí</span>
							</label>
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="radio" name="hasToken" value="no" class="w-4 h-4 text-yuc-green focus:ring-yuc-green border-slate-300">
								<span class="text-sm font-semibold text-slate-700">No</span>
							</label>
						</div>
					</div>

					<!-- Si selecciona SÍ -->
					<div id="section-yes-token" class="space-y-6 transition-all">
						
						<!-- Datos de Contacto (Confirmación) -->
						<div class="space-y-4">
							<p class="text-xs font-bold text-slate-400 uppercase tracking-widest text-center">DATOS DEL SOLICITANTE</p>
							
							<div>
								<label class="block text-xs font-bold text-slate-700 mb-1">Nombre(s) y Apellidos</label>
								<input type="text" id="frm-fullname" readonly class="w-full px-4 py-2 rounded-lg border border-slate-200 bg-slate-100 text-sm font-semibold text-slate-600" />
							</div>
							
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
								<div>
									<label class="block text-xs font-bold text-slate-700 mb-1">Correo Electrónico</label>
									<input type="email" id="frm-email" readonly class="w-full px-4 py-2 rounded-lg border border-slate-200 bg-slate-100 text-sm font-semibold text-slate-600" />
								</div>
								<div>
									<label class="block text-xs font-bold text-slate-700 mb-1">CURP</label>
									<input type="text" id="frm-curp" readonly class="w-full px-4 py-2 rounded-lg border border-slate-200 bg-slate-100 text-sm font-mono font-semibold text-slate-600 uppercase" />
								</div>
							</div>
						</div>

						<div class="border-t border-slate-200 pt-6">
							<label class="block text-sm font-bold text-yuc-green-dark mb-2 text-center font-display">Ingrese su Token (6 dígitos alfanuméricos)</label>
							<input 
								type="text" 
								id="frm-token" 
								required
								maxlength="9"
								placeholder="TK-XXXXXX" 
								class="w-full text-center px-4 py-3 rounded-lg border-2 border-slate-300 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-lg font-mono font-bold tracking-widest uppercase transition-colors" 
							/>
							<p class="text-[10px] text-slate-400 text-center mt-2">El Token le fue asignado al subir sus documentos en la pestaña "Mi Expediente Digital".</p>
						</div>

						<div class="flex items-start gap-2 pt-2">
							<input id="frm-confirm-check" type="checkbox" required class="mt-0.5 h-4 w-4 text-yuc-green focus:ring-yuc-green border-slate-300 rounded" />
							<label for="frm-confirm-check" class="block text-xs text-slate-600 leading-tight">
								He verificado mis datos y autorizo a In óolal Yucatan vincular los documentos de mi Expediente Digital con esta solicitud de trámite.
							</label>
						</div>

						<div class="text-center pt-2">
							<button type="submit" class="px-8 py-3 bg-yuc-green text-white hover:bg-yuc-green-light font-bold rounded-lg transition-colors shadow-sm font-display flex items-center justify-center mx-auto gap-2">
								<span>Validar y Solicitar Trámite</span>
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
							</button>
						</div>

					</div>

					<!-- Si selecciona NO -->
					<div id="section-no-token" class="hidden text-center space-y-4 py-6">
						<div class="w-16 h-16 rounded-full bg-amber-100 text-amber-500 flex items-center justify-center mx-auto">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
						</div>
						<p class="text-sm font-bold text-slate-800">Necesita integrar su Expediente Digital Primero</p>
						<p class="text-xs text-slate-500 leading-relaxed max-w-xs mx-auto">
							Para evitar pedirle documentos físicos cada vez que realice un trámite, suba su Identificación Oficial y Comprobante de Domicilio una sola vez. Al terminar se le dará un Token para iniciar todos sus trámites.
						</p>
						<div class="pt-2">
							<a href="/ciudadano" class="inline-block px-6 py-2.5 bg-yuc-gold text-white font-bold rounded-lg shadow-sm hover:bg-yuc-gold-light transition-colors text-sm font-display">
								Ir a Mi Expediente Digital
							</a>
						</div>
					</div>

				</form>

			</div>
		</div>

	</div>

	<script is:inline>
		// Protect page access
		const citizenLogged = localStorage.getItem('citizen_logged');
		if (citizenLogged !== 'true') {
			window.location.href = '/ciudadano/login';
		} else {
			
			// Populate user session data (Mockup of identity)
			document.getElementById('frm-curp').value = localStorage.getItem('citizen_curp') || 'N/A';
			document.getElementById('frm-email').value = localStorage.getItem('citizen_email') || 'N/A';
			document.getElementById('frm-fullname').value = localStorage.getItem('citizen_fullname') || 'Ciudadano de Prueba';

			// Parse URL parameter to determine selected procedure
			const params = new URLSearchParams(window.location.search);
			const procedureId = params.get('id') || 'residencia';

			const procedures = {
				residencia: {
					title: "Constancia de Residencia",
					dept: "Catastro y Registro del Estado de Yucatán",
				},
				licencia: {
					title: "Licencia de Funcionamiento Comercial",
					dept: "Dirección de Fomento Económico del Estado",
				},
				henequenero: {
					title: "Acreditación de Productor Henequenero",
					dept: "Secretaría de Desarrollo Rural del Estado",
				},
				suelo: {
					title: "Permiso de Uso de Suelo",
					dept: "Secretaría de Desarrollo Urbano y Obras Públicas",
				}
			};

			// Fallback if the procedure ID comes from API (Mocking title for demo)
			const currentProcedure = procedures[procedureId] || { title: "Trámite Estatal (ID: " + procedureId + ")", dept: "Dependencia Gubernamental" };

			document.getElementById('lbl-tramite-title').textContent = currentProcedure.title;
			document.getElementById('lbl-tramite-dept').textContent = `Dependencia: ${currentProcedure.dept}`;

			// Radio Button Logic
			const radios = document.querySelectorAll('input[name="hasToken"]');
			const sectionYes = document.getElementById('section-yes-token');
			const sectionNo = document.getElementById('section-no-token');

			radios.forEach(radio => {
				radio.addEventListener('change', (e) => {
					if (e.target.value === 'yes') {
						sectionYes.classList.remove('hidden');
						sectionNo.classList.add('hidden');
						document.getElementById('frm-token').setAttribute('required', 'true');
					} else {
						sectionYes.classList.add('hidden');
						sectionNo.classList.remove('hidden');
						document.getElementById('frm-token').removeAttribute('required');
					}
				});
			});

			// Form Submit Logic
			document.getElementById('token-form').addEventListener('submit', (e) => {
				e.preventDefault();

				const tokenInput = document.getElementById('frm-token').value.trim().toUpperCase();
				const confirmCheck = document.getElementById('frm-confirm-check').checked;

				if (!confirmCheck) {
					window.showToast("Debe aceptar la casilla de verificación", "error");
					return;
				}

				// Validate Token against localStorage (civicflow_tokens)
				const tokensDict = JSON.parse(localStorage.getItem('civicflow_tokens') || '{}');
				// We also allow the current active token in 'jwt_token' for demo purposes
				const activeToken = localStorage.getItem('jwt_token');

				if (!tokensDict[tokenInput] && tokenInput !== activeToken) {
					window.showToast("Token inválido o no encontrado. Verifique que lo haya escrito correctamente.", "error");
					return;
				}

				// Generate Folio
				const randomNum = Math.floor(100 + Math.random() * 900);
				const randomFolio = `TRM-2026-00${randomNum}`;
				const currentDateStr = new Date().toISOString().split('T')[0];

				// Save new request in local requests array
				const requests = JSON.parse(localStorage.getItem('in_oolal_requests') || localStorage.getItem('civicflow_requests')) || [];
				
				const newReq = {
					folio: randomFolio,
					name: currentProcedure.title,
					dept: currentProcedure.dept,
					date: currentDateStr,
					status: "Recibido",
					token: tokenInput,
					citizen_curp: localStorage.getItem('citizen_curp'),
					citizen_fullname: localStorage.getItem('citizen_fullname'),
					citizen_email: localStorage.getItem('citizen_email')
				};

				requests.push(newReq);
				localStorage.setItem('in_oolal_requests', JSON.stringify(requests));
				localStorage.setItem('civicflow_requests', JSON.stringify(requests)); // Backup for compatibility

				// Audit Log
				const localLogs = JSON.parse(localStorage.getItem('in_oolal_audit_logs') || localStorage.getItem('civicflow_audit_logs')) || [];
				localLogs.push({
					id: `LOG-${Math.floor(1000 + Math.random() * 9000)}`,
					folio: randomFolio,
					user_id: localStorage.getItem('citizen_email'),
					rol: "Ciudadano",
					estado_anterior: "-",
					estado_nuevo: "Recibido",
					ip: "Portal Ciudadano",
					timestamp: new Date().toLocaleString()
				});
				localStorage.setItem('in_oolal_audit_logs', JSON.stringify(localLogs));
				localStorage.setItem('civicflow_audit_logs', JSON.stringify(localLogs)); // Backup

				window.showToast(`¡Solicitud enviada exitosamente!`, "success");
				
				// Redirect to Success
				setTimeout(() => {
					window.location.href = `/ciudadano/exito?token=${tokenInput}&folio=${randomFolio}&tramite=${procedureId}`;
				}, 1500);

			});
		}
	</script>
</Layout>
