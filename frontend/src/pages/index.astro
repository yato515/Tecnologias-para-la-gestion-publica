---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoYucatan from '../components/img/logo-estado-yucatan.webp';
---

<Layout title="Portal de Trámites CivicFlow">
	
	<!-- Hero Section -->
	<section class="relative overflow-hidden bg-yuc-green-dark text-white py-16 sm:py-20 border-b border-yuc-gold/30">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="flex flex-col items-center text-center max-w-3xl mx-auto">
				
				<!-- Logo Oficial del Estado de Yucatán -->
				<Image
					src={logoYucatan}
					alt="Escudo Oficial del Estado de Yucatán"
					class="h-28 w-auto object-contain mb-6"
					loading="eager"
				/>

				<span class="px-3.5 py-1 rounded bg-yuc-gold/10 border border-yuc-gold/30 text-yuc-gold text-xs font-bold uppercase tracking-widest mb-6">GOBIERNO DEL ESTADO DE YUCATÁN</span>
				
				<h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-white font-display">
					Trámites Gubernamentales <br/>
					<span class="text-yuc-gold">Digitales y Transparentes</span>
				</h1>
				
				<p class="mt-6 text-sm sm:text-base text-slate-200 max-w-2xl leading-relaxed">
					Bienvenido a <strong class="text-white">CivicFlow</strong>, la ventanilla única digital del Estado de Yucatán. Reduzca filas, elimine el papeleo físico y gestione todos sus trámites con total transparencia y rapidez.
				</p>
				
				<div class="mt-8 flex flex-wrap gap-4 justify-center">
					<a href="#acceso" class="px-6 py-3 bg-yuc-gold hover:bg-yuc-gold-dark text-white font-bold rounded-lg transition-colors text-sm tracking-wide">
						Iniciar Trámite
					</a>
					<a href="#conoce-mas" class="px-6 py-3 bg-yuc-green hover:bg-yuc-green-light text-white font-bold rounded-lg border border-yuc-green-light transition-colors text-sm">
						Conocer Más
					</a>
				</div>

			</div>
		</div>
	</section>

	<!-- Selector Section (Acceso) -->
	<section id="acceso" class="py-16 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			
			<div class="text-center max-w-2xl mx-auto mb-12">
				<h2 class="text-2xl font-bold text-slate-800 font-display">Acceso al Portal</h2>
				<div class="h-1 w-16 bg-yuc-green mx-auto mt-3 rounded-full"></div>
				<p class="mt-3 text-xs text-slate-500">
					Gestione sus trámites gubernamentales de forma digital, rápida y segura desde cualquier dispositivo.
				</p>
			</div>

			<div class="flex flex-col items-center max-w-xl mx-auto gap-6">

				<!-- Citizen Card -->
				<div class="w-full bg-white border border-slate-200 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between group relative overflow-hidden">
					<!-- Top green indicator -->
					<div class="absolute top-0 left-0 w-full h-1.5 bg-yuc-green"></div>

					<div class="space-y-6">
						<div class="w-12 h-12 rounded-xl bg-yuc-green/10 text-yuc-green flex items-center justify-center">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
							</svg>
						</div>
						<div class="space-y-2">
							<h3 class="text-xl font-bold text-slate-800 font-display">Portal Ciudadano</h3>
							<p class="text-xs text-slate-500 leading-relaxed">
								Realice sus trámites gubernamentales en minutos desde la comodidad de su hogar. Registre su solicitud, cargue sus documentos una sola vez y dé seguimiento en tiempo real con su folio personal.
							</p>
						</div>
						<ul class="space-y-3 pt-2">
							<li class="flex items-center gap-3 text-xs text-slate-600">
								<svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Catálogo interactivo con búsqueda libre</span>
							</li>
							<li class="flex items-center gap-3 text-xs text-slate-600">
								<svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Formulario dinámico con validación automática</span>
							</li>
							<li class="flex items-center gap-3 text-xs text-slate-600">
								<svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Tracker en tiempo real con Folio QR</span>
							</li>
							<li class="flex items-center gap-3 text-xs text-slate-600">
								<svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Asistente de Trámites con Inteligencia Artificial</span>
							</li>
						</ul>
					</div>

					<div class="pt-6">
						<a href="/ciudadano/login" class="w-full inline-flex items-center justify-center px-6 py-3 bg-yuc-green text-white hover:bg-yuc-green-light font-bold rounded-lg shadow-sm transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 mr-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
							</svg>
							<span>Iniciar Sesión</span>
						</a>
					</div>
				</div>

				<!-- Gestor Discrete Access -->
				<div class="w-full flex items-center gap-3 text-xs text-slate-400">
					<div class="h-px flex-grow bg-slate-200"></div>
					<span>¿Eres servidor público?</span>
					<div class="h-px flex-grow bg-slate-200"></div>
				</div>
				<a href="/gestor" class="inline-flex items-center gap-2 text-xs font-semibold text-slate-500 hover:text-slate-700 transition-colors border border-slate-200 rounded-lg px-4 py-2 hover:border-slate-350">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.375m0-10.03L12 3m0 0l2.625 2.67M12 3v15.75m0 0H9m3 0h3.375M9 15h3.375M9 12h3.75m3.75-9H18a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0118 21h-2.25" />
					</svg>
					Acceso Panel Gestor
				</a>

			</div>
		</div>
	</section>

	<!-- Conoce Mas Section -->
	<section id="conoce-mas" class="py-16 bg-white border-t border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="space-y-6">
					<span class="text-xs px-2.5 py-1 rounded bg-yuc-green/10 text-yuc-green font-bold uppercase tracking-wider">Cero Burocracia</span>
					<h3 class="text-2xl font-bold text-slate-800 font-display leading-tight">Agilizando la relación Ciudadano-Gobierno</h3>
					<p class="text-slate-650 text-xs leading-relaxed">
						CivicFlow ha sido desarrollado con un enfoque centrado en el usuario, garantizando que cualquier persona pueda realizar sus gestiones de forma autónoma.
					</p>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
						<div class="flex gap-4">
							<div class="w-10 h-10 rounded-lg bg-yuc-green/10 text-yuc-green shrink-0 flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7C4.68 9.58 4.634 10.7 4.634 12c0 1.207.045 2.33.138 3.535a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.092-1.206.138-2.328.138-3.535z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5" />
								</svg>
							</div>
							<div>
								<h5 class="font-bold text-slate-800 text-xs">Transparencia Total</h5>
								<p class="text-[10px] text-slate-500 mt-1">Cada movimiento de estado queda registrado con firmas de auditoría inalterables.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-10 h-10 rounded-lg bg-yuc-green/10 text-yuc-green shrink-0 flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
								</svg>
							</div>
							<div>
								<h5 class="font-bold text-slate-800 text-xs">Accesibilidad Universal</h5>
								<p class="text-[10px] text-slate-500 mt-1">Cumplimiento estricto de contrastes y fuentes legibles para personas con debilidad visual.</p>
							</div>
						</div>
					</div>
				</div>
				<div class="relative bg-slate-50 rounded-2xl p-6 border border-slate-200 flex justify-center items-center overflow-hidden min-h-[300px]">
					<!-- Mock design graphic element -->
					<div class="w-full max-w-sm rounded-xl bg-white shadow-sm border border-slate-200 p-6 space-y-4">
						<div class="flex justify-between items-center pb-3 border-b border-slate-100">
							<span class="text-[10px] font-bold text-slate-400">TRÁMITE: TRM-2026-00342</span>
							<span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-500 font-bold text-[9px] uppercase tracking-wide">En Revisión</span>
						</div>
						<div class="space-y-2">
							<div class="h-2 w-1/3 bg-slate-100 rounded"></div>
							<div class="h-3.5 w-3/4 bg-slate-200 rounded"></div>
						</div>
						<!-- Progress step bars -->
						<div class="flex items-center gap-1 pt-2">
							<div class="h-1.5 flex-grow bg-emerald-500 rounded"></div>
							<div class="h-1.5 flex-grow bg-emerald-500 rounded"></div>
							<div class="h-1.5 flex-grow bg-slate-100 rounded"></div>
							<div class="h-1.5 flex-grow bg-slate-100 rounded"></div>
						</div>
						<p class="text-[10px] text-slate-400 font-medium">Última actualización: hace 3 minutos por Revisor Catastro</p>
					</div>
					<!-- Golden decorative element -->
					<div class="absolute -bottom-8 -right-8 w-24 h-24 bg-yuc-gold/10 rounded-full border border-yuc-gold/20"></div>
				</div>
			</div>
		</div>
	</section>

</Layout>
