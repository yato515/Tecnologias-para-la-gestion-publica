---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portal de Trámites CivicFlow">
	
	<!-- Hero Section -->
	<section class="relative overflow-hidden bg-gradient-to-b from-slate-900 via-yuc-green-dark to-slate-950 text-white py-20 sm:py-24 border-b border-yuc-gold/25">
		
		<!-- Decorative Golden Background Circles -->
		<div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[500px] h-[500px] rounded-full bg-yuc-gold/5 blur-3xl pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[600px] h-[600px] rounded-full bg-yuc-green/10 blur-3xl pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="flex flex-col items-center text-center max-w-3xl mx-auto">
				
				<!-- Large Official Coat of Arms Shield Icon -->
				<div class="w-24 h-28 flex items-center justify-center bg-yuc-green border-2 border-yuc-gold text-yuc-gold rounded-b-[40%] rounded-t-[10%] shadow-2xl mb-8 relative animate-pulse-soft">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 120" fill="none" class="w-16 h-18 text-yuc-gold">
						<!-- Sun & Mountain -->
						<circle cx="50" cy="50" r="12" stroke="currentColor" stroke-width="2" fill="currentColor" fill-opacity="0.1" />
						<path d="M50 34v6M34 50h6M60 50h6M40 40l4 4M60 40l-4 4" stroke="currentColor" stroke-width="2" />
						<!-- Deer (Venado) Jumping -->
						<path d="M35 75 C45 70, 50 60, 65 65 C70 67, 75 75, 75 75 C70 73, 62 70, 58 72 C50 75, 45 78, 35 75 Z" fill="currentColor" />
						<path d="M40 76l-3 8M48 76l-2 8M60 74l2 7M66 74l3 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
						<!-- Henequén plant silhouette -->
						<path d="M50 90c-5-5-15-5-15 0c5 5 15 5 15 0zm0 0c5-5 15-5 15 0c-5 5-15 5-15 0z" stroke="currentColor" stroke-width="2" />
						<path d="M50 78v15" stroke="currentColor" stroke-width="2" />
					</svg>
					<!-- Inner Border decoration -->
					<div class="absolute inset-1.5 border border-yuc-gold/30 rounded-b-[38%] rounded-t-[8%] pointer-events-none"></div>
				</div>

				<span class="px-3.5 py-1.5 rounded-full bg-yuc-gold/10 border border-yuc-gold/30 text-yuc-gold text-xs font-bold uppercase tracking-widest mb-6">GOBIERNO DEL ESTADO DE YUCATÁN</span>
				
				<h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-none text-white font-display">
					Trámites Gubernamentales <br/>
					<span class="bg-gradient-to-r from-yuc-gold via-yuc-gold-light to-emerald-400 bg-clip-text text-transparent">Digitales y Transparentes</span>
				</h1>
				
				<p class="mt-6 text-base sm:text-lg text-slate-300 max-w-2xl leading-relaxed">
					Bienvenido a <strong class="text-white">CivicFlow</strong>, la ventanilla única digital del Estado de Yucatán. Reduzca filas, elimine el papeleo físico y gestione todos sus trámites con total transparencia y rapidez.
				</p>
				
				<div class="mt-10 flex flex-wrap gap-4 justify-center">
					<a href="#acceso" class="px-8 py-3.5 bg-yuc-gold hover:bg-yuc-gold-light text-slate-950 font-extrabold rounded-xl shadow-lg hover:shadow-xl hover:shadow-yuc-gold/15 transition-all text-sm tracking-wide">
						Iniciar Trámite
					</a>
					<a href="#conoce-mas" class="px-8 py-3.5 bg-white/10 hover:bg-white/15 text-white font-bold rounded-xl border border-white/20 transition-all text-sm">
						Conocer Más
					</a>
				</div>

			</div>
		</div>
	</section>

	<!-- Selector Section (Acceso) -->
	<section id="acceso" class="py-20 bg-slate-50 dark:bg-bg-dark transition-colors">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			
			<div class="text-center max-w-2xl mx-auto mb-16">
				<h2 class="text-3xl font-extrabold text-slate-800 dark:text-white font-display">Seleccione su Tipo de Acceso</h2>
				<div class="h-1 w-20 bg-yuc-green mx-auto mt-4 rounded-full"></div>
				<p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
					Elija el portal ciudadano para gestionar sus trámites personales o el panel gestor si es un servidor público de alguna dependencia.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto">
				
				<!-- Citizen Card -->
				<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 rounded-2xl p-8 sm:p-10 shadow-xl hover:shadow-2xl dark:hover:border-yuc-green/40 hover:border-yuc-green/30 transition-all flex flex-col justify-between group relative overflow-hidden">
					<!-- Top green indicator -->
					<div class="absolute top-0 left-0 w-full h-1.5 bg-yuc-green"></div>
					
					<div class="space-y-6">
						<div class="w-14 h-14 rounded-2xl bg-yuc-green/10 text-yuc-green flex items-center justify-center">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
							</svg>
						</div>
						<div class="space-y-2">
							<h3 class="text-2xl font-bold text-slate-800 dark:text-white font-display">Portal Ciudadano</h3>
							<p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
								Área exclusiva para ciudadanos. Inicie solicitudes de trámites de cualquier dependencia estatal, cargue sus requisitos una sola vez y reciba notificaciones en tiempo real.
							</p>
						</div>
						<ul class="space-y-3 pt-2">
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Catálogo interactivo con búsqueda libre</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Formulario Dinámico con validación</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Tracker en tiempo real con Folio QR</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Asistente de Trámites con Inteligencia Artificial</span>
							</li>
						</ul>
					</div>
					
					<div class="pt-8">
						<a href="/ciudadano" class="w-full inline-flex items-center justify-center px-6 py-3.5 bg-yuc-green text-white hover:bg-yuc-green-light font-bold rounded-xl shadow-md transition-all group-hover:-translate-y-0.5">
							<span>Ingresar como Ciudadano</span>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</a>
					</div>
				</div>

				<!-- Gestor Card -->
				<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 rounded-2xl p-8 sm:p-10 shadow-xl hover:shadow-2xl dark:hover:border-yuc-gold/40 hover:border-yuc-gold/30 transition-all flex flex-col justify-between group relative overflow-hidden">
					<!-- Top gold indicator -->
					<div class="absolute top-0 left-0 w-full h-1.5 bg-yuc-gold"></div>
					
					<div class="space-y-6">
						<div class="w-14 h-14 rounded-2xl bg-yuc-gold/10 text-yuc-gold-dark dark:text-yuc-gold flex items-center justify-center">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.375m0-10.03L12 3m0 0l2.625 2.67M12 3v15.75m0 0H9m3 0h3.375M9 15h3.375M9 12h3.75m3.75-9H18a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0118 21h-2.25" />
							</svg>
						</div>
						<div class="space-y-2">
							<h3 class="text-2xl font-bold text-slate-800 dark:text-white font-display">Panel Gestor</h3>
							<p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
								Acceso para revisores y aprobadores de las dependencias estatales. Supervise la carga de solicitudes, valide documentos y resuelva solicitudes de forma digital y segura.
							</p>
						</div>
						<ul class="space-y-3 pt-2">
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Dashboard con Semáforo de Carga Laboral</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Cola de solicitudes dividida y filtrada</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Acciones: Aprobar, Rechazar (Plantillas), Corregir</span>
							</li>
							<li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
								<svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
								<span>Firma Electrónica Simple & Certificado PDF</span>
							</li>
						</ul>
					</div>
					
					<div class="pt-8">
						<a href="/gestor" class="w-full inline-flex items-center justify-center px-6 py-3.5 bg-slate-800 dark:bg-slate-700 hover:bg-slate-700 dark:hover:bg-slate-600 text-white font-bold rounded-xl shadow-md transition-all group-hover:-translate-y-0.5 border border-slate-700">
							<span>Ingresar como Gestor</span>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</a>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Conoce Mas Section -->
	<section id="conoce-mas" class="py-20 bg-white dark:bg-slate-950 border-t border-slate-200 dark:border-slate-900 transition-colors">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="space-y-6">
					<span class="text-xs px-3 py-1.5 rounded-md bg-yuc-green/10 text-yuc-green dark:text-yuc-green-light font-bold uppercase tracking-wider">Cero Burocracia</span>
					<h3 class="text-3xl font-extrabold text-slate-800 dark:text-white font-display leading-tight">Agilizando la relación Ciudadano-Gobierno</h3>
					<p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
						CivicFlow ha sido desarrollado con un enfoque centrado en el usuario, garantizando que cualquier persona pueda realizar sus gestiones de forma autónoma.
					</p>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
						<div class="flex gap-4">
							<div class="w-10 h-10 rounded-lg bg-yuc-green/10 text-yuc-green shrink-0 flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7C4.68 9.58 4.634 10.7 4.634 12c0 1.207.045 2.33.138 3.535a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.092-1.206.138-2.328.138-3.535z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5" />
								</svg>
							</div>
							<div>
								<h5 class="font-bold text-slate-800 dark:text-white text-sm">Transparencia Total</h5>
								<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Cada movimiento de estado queda registrado con firmas de auditoría inalterables.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-10 h-10 rounded-lg bg-yuc-green/10 text-yuc-green shrink-0 flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
								</svg>
							</div>
							<div>
								<h5 class="font-bold text-slate-800 dark:text-white text-sm">Accesibilidad Universal</h5>
								<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Cumplimiento estricto de contrastes y fuentes legibles para personas con debilidad visual.</p>
							</div>
						</div>
					</div>
				</div>
				<div class="relative bg-slate-100 dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 flex justify-center items-center shadow-inner overflow-hidden min-h-[300px]">
					<!-- Mock design graphic element -->
					<div class="w-full max-w-sm rounded-xl bg-white dark:bg-slate-950 shadow-xl border border-slate-200 dark:border-slate-800 p-6 space-y-4">
						<div class="flex justify-between items-center pb-3 border-b border-slate-100 dark:border-slate-900">
							<span class="text-xs font-bold text-slate-400">TRÁMITE: TRM-2026-00342</span>
							<span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-500 font-bold text-[9px] uppercase tracking-wide">En Revisión</span>
						</div>
						<div class="space-y-2">
							<div class="h-2.5 w-1/3 bg-slate-200 dark:bg-slate-800 rounded"></div>
							<div class="h-4 w-3/4 bg-slate-300 dark:bg-slate-700 rounded"></div>
						</div>
						<!-- Progress step bars -->
						<div class="flex items-center gap-1 pt-2">
							<div class="h-1.5 flex-grow bg-emerald-500 rounded"></div>
							<div class="h-1.5 flex-grow bg-emerald-500 rounded"></div>
							<div class="h-1.5 flex-grow bg-slate-200 dark:bg-slate-850 rounded"></div>
							<div class="h-1.5 flex-grow bg-slate-200 dark:bg-slate-850 rounded"></div>
						</div>
						<p class="text-[10px] text-slate-400">Última actualización: hace 3 minutos por Revisor Catastro</p>
					</div>
					<!-- Golden decorative square -->
					<div class="absolute -bottom-8 -right-8 w-24 h-24 bg-yuc-gold/10 rounded-full border border-yuc-gold/20"></div>
				</div>
			</div>
		</div>
	</section>

</Layout>
