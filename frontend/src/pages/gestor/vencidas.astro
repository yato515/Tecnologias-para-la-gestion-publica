---
import Layout from '../../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Solicitudes Vencidas (Control de Eficiencia) - In óolal Yucatan">
	
	<!-- Manager Sub-navigation header -->
	<div class="bg-yuc-green-dark text-white transition-colors border-b border-yuc-gold/30">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4">
				<div>
					<span class="text-xs font-bold text-yuc-gold uppercase tracking-wider">GOBIERNO DEL ESTADO DE YUCATÁN</span>
					<h1 class="text-2xl font-black font-display mt-1">Control de Plazos y Eficiencia</h1>
					<p class="text-xs text-slate-300 mt-1">Funcionario: <span id="lbl-gestor-email-venc" class="font-bold text-white">...</span> | Rol: <span id="lbl-gestor-role-venc" class="font-bold text-yuc-gold">...</span></p>
				</div>
				<div class="flex items-center gap-3">
					<button id="btn-gestor-logout" class="px-4 py-2 border border-yuc-gold/30 hover:bg-yuc-green text-slate-200 rounded-lg text-xs font-bold transition-all">Cerrar Sesión</button>
				</div>
			</div>

			<!-- Submenu -->
			<div class="flex gap-6 text-sm border-t border-yuc-gold/20 pt-1">
				<a href="/gestor/dashboard" class="pb-3 border-b-2 border-transparent text-slate-300 hover:text-white transition-all">Mesa de Trabajo</a>
				<a href="/gestor/vencidas" class="pb-3 border-b-2 border-yuc-gold text-yuc-gold font-bold transition-all flex items-center gap-1.5">
					<span>Solicitudes Vencidas</span>
					<span id="badge-vencidas-count" class="hidden px-1.5 py-0.5 rounded-full bg-red-600 text-white font-extrabold text-[9px]">0</span>
				</a>
				<a href="/gestor/cola" class="pb-3 border-b-2 border-transparent text-slate-300 hover:text-white transition-all">Bandeja de Entrada</a>
				<a href="/gestor/audit" class="pb-3 border-b-2 border-transparent text-slate-300 hover:text-white transition-all">Logs de Auditoría</a>
				<a href="#" id="tab-admin-venc" class="hidden pb-3 border-b-2 border-transparent text-slate-300 hover:text-white transition-all flex items-center gap-1.5">
					<svg class="w-4 h-4 text-yuc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
					<span>Administrar Cuentas</span>
				</a>
			</div>
		</div>
	</div>

	<!-- Main Workspace -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
		
		<div id="vencidas-content" class="space-y-6">
			
			<!-- High Priority Alert Banner -->
			<div class="p-5 rounded-2xl border border-red-200 bg-red-500/5 dark:bg-red-950/15 flex gap-4 items-start">
				<div class="w-10 h-10 rounded-xl bg-red-600/10 dark:bg-red-500/10 text-red-650 dark:text-red-500 flex items-center justify-center shrink-0 animate-pulse">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
				</div>
				<div class="space-y-1">
					<h3 class="text-sm font-extrabold text-red-800 dark:text-red-400 uppercase tracking-wide">Monitoreo de Plazos Excedidos</h3>
					<p class="text-xs text-red-755 dark:text-slate-300 leading-relaxed">
						Se listan de forma exclusiva los expedientes que superan el <strong class="underline">Plazo Máximo de Atención (3 días hábiles)</strong>. De conformidad con las normas de gobernanza digital, estas solicitudes deben ser dictaminadas de forma prioritaria bajo sanción administrativa por dilación.
					</p>
				</div>
			</div>

			<!-- Filter Metric Card -->
			<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm flex items-center justify-between">
				<div class="space-y-0.5">
					<span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">Registros Vencidos Detectados</span>
					<div class="flex items-baseline gap-2">
						<span id="lbl-vencidas-metric" class="text-3xl font-black text-red-650 font-display">0</span>
						<span class="text-xs text-slate-500">solicitudes fuera de tiempo de atención</span>
					</div>
				</div>
				<button id="btn-force-refresh" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 text-slate-700 dark:text-slate-350 text-xs font-bold rounded-lg border border-slate-200/50 dark:border-slate-750 flex items-center gap-1.5 transition-colors">
					<svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"></path></svg>
					<span>Re-evaluar plazos</span>
				</button>
			</div>

			<!-- Red Highlighted List of Overdue items -->
			<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
				<div class="overflow-x-auto font-sans">
					<table class="w-full text-left border-collapse">
						<thead>
							<tr class="bg-slate-50 dark:bg-slate-950/40 text-slate-550 text-[10px] font-bold uppercase tracking-wider border-b border-slate-200 dark:border-slate-800">
								<th class="px-6 py-4">Folio</th>
								<th class="px-6 py-4">Trámite / Área</th>
								<th class="px-6 py-4">Ciudadano</th>
								<th class="px-6 py-4">Fecha Registro</th>
								<th class="px-6 py-4 text-red-650">Días Transcurridos</th>
								<th class="px-6 py-4">Estatus Técnico</th>
								<th class="px-6 py-4 text-right">Acción Emergente</th>
							</tr>
						</thead>
						<tbody id="vencidas-tbody" class="divide-y divide-slate-200/60 dark:divide-slate-800/60 text-xs text-slate-700 dark:text-slate-350">
							<!-- Rendered dynamically -->
						</tbody>
					</table>
				</div>

				<!-- Empty State -->
				<div id="vencidas-empty-msg" class="hidden text-center py-16 space-y-3">
					<div class="w-12 h-12 rounded-full bg-emerald-500/10 text-emerald-500 flex items-center justify-center mx-auto">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0110 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0114 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
					</div>
					<p class="text-slate-500 dark:text-slate-400 text-xs font-semibold">¡Excelente! Ninguna solicitud excede el tiempo límite en este momento.</p>
				</div>
			</div>

		</div>

	</div>

	<script is:inline define:vars={{ API_URL }}>
		// Protect Route
		const gestorLogged = localStorage.getItem('gestor_logged');
		if (gestorLogged !== 'true') {
			window.location.href = '/gestor';
		} else {
			// Populate header
			const gestorEmail = localStorage.getItem('gestor_email') || 'N/A';
			const gestorRole = localStorage.getItem('gestor_role') || 'N/A';
			document.getElementById('lbl-gestor-email-venc').textContent = gestorEmail;
			document.getElementById('lbl-gestor-role-venc').textContent = gestorRole;
			if (gestorRole.toLowerCase() === 'aprobador') {
				document.getElementById('tab-admin-venc').classList.remove('hidden');
				document.getElementById('tab-admin-venc').href = '/gestor/dashboard?tab=admin';
			}
			
			document.getElementById('btn-gestor-logout').addEventListener('click', () => {
				localStorage.removeItem('gestor_logged');
				localStorage.removeItem('gestor_email');
				localStorage.removeItem('gestor_role');
				window.showToast("Sesión de gestor cerrada", "info");
				setTimeout(() => {
					window.location.href = '/gestor';
				}, 600);
			});

			const getRequests = async () => {
				try {
					const depId = localStorage.getItem('gestor_dependencia_id');
					const url = depId ? `${API_URL}/api/gestores/solicitudes?dependencia_id=${depId}` : `${API_URL}/api/gestores/solicitudes`;
					const res = await fetch(url);
					const json = await res.json();
					if (json.success && Array.isArray(json.data)) {
						const mapEstado = {
							'recibido': 'Recibido',
							'en_revision': 'En revisión',
							'documentacion_incompleta': 'Documentación incompleta',
							'aprobado': 'Aprobado',
							'rechazado': 'Rechazado'
						};
						return json.data.map(r => ({
							id: r.id,
							folio: r.folio || r.id,
							name: r.tramite?.nombre || 'Trámite Genérico',
							dept: r.dependencia?.nombre || 'Dependencia',
							date: r.created_at ? r.created_at.split('T')[0] : new Date().toISOString().split('T')[0],
							status: mapEstado[r.estado] || r.estado || 'Recibido',
							citizen_fullname: r.ciudadano?.nombre_completo || 'Ciudadano'
						}));
					}
					return [];
				} catch (e) {
					console.error(e);
					return [];
				}
			};

			const renderVencidas = async () => {
				const tbody = document.getElementById('vencidas-tbody');
				const emptyMsg = document.getElementById('vencidas-empty-msg');
				const requests = await getRequests();

				tbody.innerHTML = '';
				
				const currentDate = new Date('2026-05-22'); // system reference date
				let count = 0;

				requests.reverse().forEach(r => {
					// Check if status is open (pending, in-review)
					const isOpen = r.status === 'Recibido' || r.status === 'En revisión' || r.status === 'En revisión con sistemas oficiales';
					
					if (isOpen) {
						const reqDate = new Date(r.date);
						const diffTime = Math.abs(currentDate - reqDate);
						const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

						// If 3 or more days, it is overdue
						if (diffDays >= 3) {
							count++;

							const tr = document.createElement('tr');
							tr.className = "hover:bg-red-500/5 transition-colors border-l-4 border-red-650 bg-red-650/[0.01]";
							
							tr.innerHTML = `
								<td class="px-6 py-4 font-mono font-bold text-red-655 dark:text-red-500">${r.folio}</td>
								<td class="px-6 py-4">
									<p class="font-bold text-slate-800 dark:text-white leading-tight">${r.name}</p>
									<p class="text-[10px] text-slate-400 leading-none mt-0.5">${r.dept}</p>
								</td>
								<td class="px-6 py-4 font-semibold">${r.citizen_fullname || 'N/A'}</td>
								<td class="px-6 py-4">${r.date}</td>
								<td class="px-6 py-4 font-black text-red-650 dark:text-red-400 flex items-center gap-1.5">
									<span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-ping"></span>
									<span>${diffDays} días</span>
								</td>
								<td class="px-6 py-4">
									<span class="px-2 py-0.5 rounded-full bg-red-500/10 text-red-650 border border-red-500/20 font-bold uppercase text-[9px]">
										ATENCIÓN INMEDIATA
									</span>
								</td>
								<td class="px-6 py-4 text-right">
									<a href="/gestor/solicitud?id=${r.folio}" class="px-3.5 py-2 bg-red-650 hover:bg-red-600 text-white font-extrabold rounded-lg transition-all inline-flex items-center gap-1 shadow-md shadow-red-500/10">
										<span>Atender De Emergencia</span>
										<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
									</a>
								</td>
							`;
							tbody.appendChild(tr);
						}
					}
				});

				// Update metrics
				document.getElementById('lbl-vencidas-metric').textContent = count;
				
				// Update overdue badge count in subnav
				const badgeOverdue = document.getElementById('badge-vencidas-count');
				if (count > 0) {
					badgeOverdue.textContent = count;
					badgeOverdue.classList.remove('hidden');
					emptyMsg.classList.add('hidden');
				} else {
					badgeOverdue.classList.add('hidden');
					emptyMsg.classList.remove('hidden');
				}
			};

			// Initial load
			renderVencidas();

			// Force re-evaluate click handler
			document.getElementById('btn-force-refresh').addEventListener('click', () => {
				renderVencidas();
				window.showToast("Cálculo de plazos re-evaluado", "success");
			});

			// Sincronización
			window.addEventListener('storage', (e) => {
				if (e.key === 'civicflow_requests') {
					renderVencidas();
				}
			});

		}
	</script>
</Layout>
