---
import Layout from '../../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Acceso de Servidores Públicos - Panel Gestor">
	<div class="min-h-[calc(100vh-13rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-900 relative overflow-hidden">
		
		<!-- Background decorative elements -->
		<div class="absolute inset-0 z-0">
			<div class="absolute inset-0 bg-[url('/bg-pattern.svg')] opacity-10"></div>
			<div class="absolute top-0 right-0 -mr-32 -mt-32 w-96 h-96 rounded-full bg-yuc-green/20 blur-3xl"></div>
			<div class="absolute bottom-0 left-0 -ml-32 -mb-32 w-96 h-96 rounded-full bg-yuc-gold/20 blur-3xl"></div>
		</div>

		<div class="max-w-md w-full space-y-8 bg-white p-8 sm:p-10 rounded-2xl shadow-2xl relative z-10 border-t-4 border-t-yuc-gold">
			
			<div class="text-center">
				<div class="mx-auto w-14 h-14 rounded-full bg-slate-900 text-yuc-gold flex items-center justify-center mb-4 shadow-md">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.375m0-10.03L12 3m0 0l2.625 2.67M12 3v15.75m0 0H9m3 0h3.375M9 15h3.375M9 12h3.75m3.75-9H18a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0118 21h-2.25" />
					</svg>
				</div>
				<h2 class="text-2xl font-bold text-slate-800 font-display">Panel Gestor</h2>
				<p class="mt-2 text-xs text-slate-500">
					Módulo interno para validación, revisión y firma de expedientes digitales.
				</p>
			</div>

			<form class="mt-8 space-y-6" id="gestor-login-form">
				<div class="space-y-4">
					
					<!-- Email Field -->
					<div>
						<label for="email" class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Correo Institucional</label>
						<input 
							id="email" 
							name="email" 
							type="email" 
							required 
							class="block w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm"
							placeholder="servidor@yucatan.gob.mx"
						/>
					</div>

					<!-- Password Field -->
					<div>
						<label for="password" class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Contraseña</label>
						<input 
							id="password" 
							name="password" 
							type="password" 
							required 
							class="block w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm"
							placeholder="••••••••"
						/>
					</div>

					<!-- Role selection removed -->

				</div>

				<div>
					<button 
						type="submit" 
						class="w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-md text-sm font-bold text-white bg-slate-900 hover:bg-yuc-green focus:ring-2 focus:ring-yuc-green transition-colors"
					>
						Ingresar al Módulo Gestor
					</button>
				</div>
                <div class="mt-4 text-center">
                    <a href="#" id="forgot-password" class="font-bold text-xs text-slate-500 hover:text-yuc-green hover:underline transition-colors">¿Olvidó su contraseña institucional?</a>
                </div>
			</form>

			<!-- Testing info -->
			<div class="mt-4 p-4 rounded-xl bg-slate-100 border border-slate-200 text-xs">
				<p class="font-bold text-slate-800">Credenciales Demo:</p>
				<ul class="text-slate-500 mt-1.5 space-y-1">
					<li>• Revisor: <code class="text-yuc-green font-bold bg-slate-200/50 px-1 rounded">revisor@yucatan.gob.mx</code></li>
					<li>• Aprobador: <code class="text-yuc-green font-bold bg-slate-200/50 px-1 rounded">director@yucatan.gob.mx</code></li>
				</ul>
			</div>

		</div>
	</div>

	<script is:inline define:vars={{ API_URL }}>
		const form = document.getElementById('gestor-login-form');
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = document.getElementById('email').value.trim();
			const password = document.getElementById('password').value;

			let loginSuccess = false;
			let role = '';
			try {
				const res = await fetch(`${API_URL}/api/auth/login`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, password })
				});
				const json = await res.json();
				if (json.success && json.user) {
					localStorage.setItem('gestor_logged', 'true');
					localStorage.setItem('gestor_email', json.user.email);
					role = json.user.rol;
					loginSuccess = true;
				} else {
					window.showToast(json.message || "Credenciales inválidas en el servidor.", "error");
					return;
				}
			} catch (_) {
				// Fallback local en desarrollo/modo demo
				role = 'Revisor';
				loginSuccess = true;
			}

			if (loginSuccess) {
				// Aseguramos persistencia local de rol y login para demo
				localStorage.setItem('gestor_logged', 'true');
				localStorage.setItem('gestor_email', email);
				localStorage.setItem('gestor_role', role);

				window.showToast(`Bienvenido al sistema. Rol: ${role}`, "success");

				setTimeout(() => {
					window.location.href = '/gestor/dashboard';
				}, 800);
			}
		});

		document.getElementById('forgot-password').addEventListener('click', async (e) => {
			e.preventDefault();
			const email = document.getElementById('email').value.trim();
			if (!email) {
				window.showToast("Por favor, ingresa tu correo institucional primero.", "error");
				return;
			}
			try {
				const res = await fetch(`${API_URL}/api/auth/recuperar`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email })
				});
				const json = await res.json();
				if (json.success) {
					window.showToast("Se ha enviado un enlace de recuperación a tu correo.", "success");
				} else {
					window.showToast(json.message || "Error al recuperar la contraseña.", "error");
				}
			} catch (err) {
				window.showToast("Error al conectar con el servidor.", "error");
			}
		});
	</script>
</Layout>
