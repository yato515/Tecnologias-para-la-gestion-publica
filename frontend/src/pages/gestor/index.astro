---
import Layout from '../../layouts/Layout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Acceso de Servidores Públicos - Panel Gestor">
	<div class="min-h-[calc(100vh-13rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50 relative overflow-hidden">
		
		<div class="max-w-md w-full space-y-8 bg-white p-8 sm:p-10 rounded-2xl border border-slate-200 shadow-sm relative z-10">
			
			<div class="text-center">
				<div class="mx-auto w-12 h-12 rounded-xl bg-yuc-gold/10 text-yuc-gold-dark flex items-center justify-center mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.375m0-10.03L12 3m0 0l2.625 2.67M12 3v15.75m0 0H9m3 0h3.375M9 15h3.375M9 12h3.75m3.75-9H18a2.25 2.25 0 012.25 2.25v13.5A2.25 2.25 0 0118 21h-2.25" />
					</svg>
				</div>
				<h2 class="text-2xl font-bold text-slate-800 font-display">Panel Gestor</h2>
				<p class="mt-2 text-xs text-slate-500">
					Módulo interno para validación, revisión y firma de expedientes digitales.
				</p>
			</div>

			<form class="mt-8 space-y-6" id="gestor-login-form">
				<div class="space-y-4">
					
					<!-- Email Field -->
					<div>
						<label for="email" class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Correo Institucional</label>
						<input 
							id="email" 
							name="email" 
							type="email" 
							required 
							class="block w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm"
							placeholder="servidor@yucatan.gob.mx"
						/>
					</div>

					<!-- Password Field -->
					<div>
						<label for="password" class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Contraseña</label>
						<input 
							id="password" 
							name="password" 
							type="password" 
							required 
							class="block w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm"
							placeholder="••••••••"
						/>
					</div>

					<!-- Role selection -->
					<div>
						<label for="role" class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Rol / Permisos del Funcionario</label>
						<select 
							id="role" 
							name="role" 
							required
							class="block w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-yuc-green focus:border-yuc-green text-sm"
						>
							<option value="Revisor">Revisor (Catastro / SDR) - Puede comentar y pre-evaluar</option>
							<option value="Aprobador">Aprobador (Director de Dependencia) - Puede dictaminar y firmar</option>
						</select>
					</div>

				</div>

				<div>
					<button 
						type="submit" 
						class="w-full flex justify-center py-3.5 px-4 border border-slate-300 rounded-xl shadow-sm text-sm font-bold text-slate-800 bg-white hover:bg-slate-50 transition-colors border border-slate-350"
					>
						Ingresar al Módulo Gestor
					</button>
				</div>
			</form>

			<!-- Testing info -->
			<div class="mt-4 p-4 rounded-xl bg-slate-100 border border-slate-200 text-xs">
				<p class="font-bold text-slate-800">Credenciales Demo:</p>
				<ul class="text-slate-500 mt-1.5 space-y-1">
					<li>• Revisor: <code class="text-yuc-green font-bold bg-slate-200/50 px-1 rounded">revisor@yucatan.gob.mx</code></li>
					<li>• Aprobador: <code class="text-yuc-green font-bold bg-slate-200/50 px-1 rounded">director@yucatan.gob.mx</code></li>
				</ul>
			</div>

		</div>
	</div>

	<script is:inline define:vars={{ API_URL }}>
		const form = document.getElementById('gestor-login-form');
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = document.getElementById('email').value.trim();
			const password = document.getElementById('password').value;
			const role = document.getElementById('role').value;

			try {
				const res = await fetch(`${API_URL}/api/auth/login`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, password })
				});
				const json = await res.json();
				if (json.success && json.token) {
					localStorage.setItem('jwt_token_gestor', json.token);
					localStorage.setItem('gestor_logged', 'true');
					localStorage.setItem('gestor_email', json.user.email);
				}
			} catch (_) {
				// Fallback local en desarrollo/modo demo
			}

			// Aseguramos persistencia local de rol y login para demo
			localStorage.setItem('gestor_logged', 'true');
			localStorage.setItem('gestor_email', email);
			localStorage.setItem('gestor_role', role);

			window.showToast(`Bienvenido al sistema. Rol: ${role}`, "success");

			setTimeout(() => {
				window.location.href = '/gestor/dashboard';
			}, 800);
		});
	</script>
</Layout>
